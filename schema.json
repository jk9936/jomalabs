{
  "name": "Premium Hero Carousel",
  "settings": [
    {
      "type": "select",
      "id": "container_width",
      "label": "Container Width",
      "options": [
        { "value": "standard", "label": "Standard (1600px)" },
        { "value": "narrow", "label": "Narrow (1200px)" },
        { "value": "full", "label": "Full Width" }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full Screen" }
      ],
      "default": "large"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 0,
      "max": 60,
      "step": 2,
      "default": 24,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show Pagination Dots",
      "default": true
    },
    {
      "type": "header",
      "content": "Effects"
    },
    {
      "type": "checkbox",
      "id": "enable_floating_animation",
      "label": "Enable Floating Products",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "enable_mouse_parallax",
      "label": "Enable Mouse Parallax",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "settings": [
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Introducing"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The New Standard."
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>A premium design experience built seamlessly into your store.</p>"
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Discover More"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image (Transparent PNG recommended)"
        },
        {
          "type": "image_picker",
          "id": "badge_image",
          "label": "Floating Badge Image"
        },
        {
          "type": "header",
          "content": "Theme & Colors"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#f4f4f4"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent Color",
          "default": "#e1e1e1"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#111111"
        },
        {
          "type": "select",
          "id": "bg_type",
          "label": "Background Style",
          "options": [
            { "value": "solid", "label": "Solid Color" },
            { "value": "gradient", "label": "Linear Gradient" },
            { "value": "mesh", "label": "Animated Mesh Gradient" },
            { "value": "noise", "label": "Grain/Noise" },
            { "value": "image", "label": "Background Image" }
          ],
          "default": "solid"
        },
        {
          "type": "image_picker",
          "id": "bg_image",
          "label": "Background Image (if selected)"
        },
        {
          "type": "select",
          "id": "decoration_style",
          "label": "Decoration Overlay",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "circle", "label": "Blurred Circle" },
            { "value": "grid", "label": "Minimal Grid" },
            { "value": "blobs", "label": "Animated Blobs" }
          ],
          "default": "circle"
        },
        {
          "type": "header",
          "content": "Product Presentation"
        },
        {
          "type": "checkbox",
          "id": "floating",
          "label": "Float this product",
          "default": true
        },
        {
          "type": "range",
          "id": "image_scale",
          "label": "Image Scale (%)",
          "min": 50,
          "max": 200,
          "step": 5,
          "default": 100
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Base Rotation",
          "min": -45,
          "max": 45,
          "step": 1,
          "default": 0,
          "unit": "deg"
        },
        {
          "type": "range",
          "id": "shadow",
          "label": "Shadow Distance",
          "min": 0,
          "max": 100,
          "step": 5,
          "default": 20,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "pos_x_desktop",
          "label": "Desktop Horizontal Offset",
          "min": -200,
          "max": 200,
          "step": 5,
          "default": 0,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "pos_y_desktop",
          "label": "Desktop Vertical Offset",
          "min": -200,
          "max": 200,
          "step": 5,
          "default": 0,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "pos_x_mobile",
          "label": "Mobile Horizontal Offset",
          "min": -200,
          "max": 200,
          "step": 5,
          "default": 0,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "pos_y_mobile",
          "label": "Mobile Vertical Offset",
          "min": -200,
          "max": 200,
          "step": 5,
          "default": 0,
          "unit": "px"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Hero Carousel",
      "blocks": [
        {
          "type": "slide",
          "settings": {
            "heading": "Designed to Inspire.",
            "bg_type": "mesh",
            "decoration_style": "grid"
          }
        },
        {
          "type": "slide",
          "settings": {
            "heading": "Crafted with Precision.",
            "bg_type": "noise",
            "decoration_style": "circle",
            "bg_color": "#111111",
            "accent_color": "#333333",
            "text_color": "#ffffff"
          }
        }
      ]
    }
  ]
}
