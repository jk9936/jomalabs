      },
      {
        "type": "image_picker",
        "id": "share_image",
        "label": "Default social sharing image",
        "info": "Used as fallback for Open Graph. Recommended: 1200×630px."
      }
    ]
  },
  {
    "name": "Colors",
    "settings": [
      {
        "type": "color",
        "id": "color_primary",
        "label": "Primary (Forest Green)",
        "default": "#18241b"
      },
      {
        "type": "color",
        "id": "color_secondary",
        "label": "Secondary (Terracotta)",
        "default": "#974723"
      },
      {
        "type": "color",
        "id": "color_background",
        "label": "Background (Cream)",
        "default": "#fff8f4"
      },
      {
        "type": "color",
        "id": "color_on_surface",
        "label": "Body text color",
        "default": "#1f1b17"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "select",
        "id": "font_headline",
        "label": "Headline font",
        "options": [
          { "value": "Literata", "label": "Literata (Serif — default)" },
          { "value": "Playfair Display", "label": "Playfair Display (Serif)" },
          { "value": "Cormorant Garamond", "label": "Cormorant Garamond (Serif)" }
