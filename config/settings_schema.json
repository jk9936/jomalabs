        "default": "Literata"
      },
      {
        "type": "select",
        "id": "font_body",
        "label": "Body font",
        "options": [
          { "value": "Hanken Grotesk", "label": "Hanken Grotesk (Sans — default)" },
          { "value": "Inter", "label": "Inter (Sans)" },
          { "value": "DM Sans", "label": "DM Sans (Sans)" }
        ],
        "default": "Hanken Grotesk"
      }
    ]
  },
  {
    "name": "Favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "Favicon",
        "info": "32×32px recommended. PNG or ICO."
