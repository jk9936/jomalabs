{% doc %}
  @prompt
    Create a Process section with a looping background video. Use this video URL as the default background video: https://cdn.shopify.com/videos/c/vp/b6da383bf765422c863ef229d2f60910/b6da383bf765422c863ef229d2f60910.HD-1080p-7.2Mbps-89150810.mp4 - The video should autoplay, loop, and be muted. Display process steps (title, number, description) overlaid on top with a semi-transparent overlay for readability. The video is portrait orientation so use object-fit: cover to fill the section width. All content should be editable from the theme editor.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-process-video-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    min-height: {{ block.settings.section_height }}px;
    overflow: hidden;
    display: block;
  }

  .ai-process-video__background-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .ai-process-video__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-process-video__overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
    z-index: 2;
  }

  .ai-process-video__content-{{ ai_gen_id }} {
    position: relative;
    z-index: 3;
    padding: {{ block.settings.padding_vertical }}px {{ block.settings.padding_horizontal }}px;
    display: flex;
    flex-direction: column;
    gap: 48px;
    min-height: {{ block.settings.section_height }}px;
    justify-content: center;
  }

  .ai-process-video__heading-{{ ai_gen_id }} {
    font-family: var(--font-serif) !important;
    font-size: var(--text-display-lg);
    font-weight: 600;
    color: var(--color-primary);
    margin: 0;
    text-align: left;
  }

  .ai-process-video__steps-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: 40px;
    max-width: {{ block.settings.content_max_width }}px;
    margin: 0 auto;
    width: 100%;
  }

  .ai-process-video__step-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    text-align: left;
  }

  .ai-process-video__step-number-{{ ai_gen_id }} {
    font-family: var(--font-serif) !important;
    font-size: 48px;
    color: var(--color-surface-dim);
    line-height: 1;
    margin-bottom: 8px;
  }

  .ai-process-video__step-title-{{ ai_gen_id }} {
    font-family: var(--font-serif) !important;
    font-size: 22px;
    font-weight: 600;
    color: var(--color-primary);
    margin: 0 0 12px 0;
  }

  .ai-process-video__step-description-{{ ai_gen_id }} {
    font-family: var(--font-sans) !important;
    font-size: 17px;
    color: var(--color-on-surface-variant);
    line-height: 1.7;
    margin: 0;
  }

  @media screen and (max-width: 767px) {
    .ai-process-video__steps-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-process-video__heading-{{ ai_gen_id }} {
      font-size: var(--text-headline-lg);
      text-align: left;
    }

    .ai-process-video__step-number-{{ ai_gen_id }} {
      font-size: 40px;
    }

    .ai-process-video__content-{{ ai_gen_id }} {
      padding: 64px 20px;
      gap: 32px;
    }
    
    .ai-process-video__step-{{ ai_gen_id }} {
      text-align: left;
    }
  }
{% endstyle %}

<process-video-{{ ai_gen_id }} class="ai-process-video-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-process-video__background-{{ ai_gen_id }}">
    {% if block.settings.video_url != blank %}
      <video
        class="ai-process-video__video-{{ ai_gen_id }}"
        autoplay
        loop
        muted
        playsinline
        aria-hidden="true"
      >
        <source src="{{ block.settings.video_url }}" type="video/mp4">
      </video>
    {% endif %}
  </div>

  <div class="ai-process-video__overlay-{{ ai_gen_id }}"></div>

  <div class="ai-process-video__content-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-process-video__heading-{{ ai_gen_id }} font-serif">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-process-video__steps-{{ ai_gen_id }}">
      {% for i in (1..6) %}
        {% liquid
          assign step_enabled_key = 'step_' | append: i | append: '_enabled'
          assign step_number_key = 'step_' | append: i | append: '_number'
          assign step_title_key = 'step_' | append: i | append: '_title'
          assign step_description_key = 'step_' | append: i | append: '_description'

          assign step_enabled = block.settings[step_enabled_key]
          assign step_number = block.settings[step_number_key]
          assign step_title = block.settings[step_title_key]
          assign step_description = block.settings[step_description_key]
        %}

        {% if step_enabled %}
          <div class="ai-process-video__step-{{ ai_gen_id }}">
            {% if step_number != blank %}
              <div class="ai-process-video__step-number-{{ ai_gen_id }} font-serif">{{ step_number }}</div>
            {% endif %}
            {% if step_title != blank %}
              <h3 class="ai-process-video__step-title-{{ ai_gen_id }} font-serif">{{ step_title }}</h3>
            {% endif %}
            {% if step_description != blank %}
              <div class="ai-process-video__step-description-{{ ai_gen_id }} font-sans">{{ step_description }}</div>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</process-video-{{ ai_gen_id }}>

<script>
  (function() {
    class ProcessVideo{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-process-video__video-{{ ai_gen_id }}');
        if (this.video) {
          this.ensureVideoPlays();
        }
      }

      ensureVideoPlays() {
        const playPromise = this.video.play();
        if (playPromise !== undefined) {
          playPromise.catch(() => {
            this.video.muted = true;
            this.video.play();
          });
        }
      }
    }

    customElements.define('process-video-{{ ai_gen_id }}', ProcessVideo{{ ai_gen_id }});
  })();
</script>

