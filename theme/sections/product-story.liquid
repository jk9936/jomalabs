{%- liquid
  assign bg_type = section.settings.bg_type
  assign bg_color = section.settings.bg_color | default: 'var(--color-background)'
  assign accent_color = section.settings.accent_color | default: 'var(--color-secondary)'
  assign text_color = section.settings.text_color | default: 'var(--color-on-surface)'
  assign decor_style = section.settings.decoration_style
  
  assign media_block = section.blocks | where: "type", "media" | first
-%}

{%- style -%}
  /* Scoped CSS for Product Story Section */
  #shopify-section-{{ section.id }} {
    --ps-bg-color: {{ bg_color }};
    --ps-accent-color: {{ accent_color }};
    --ps-text-color: {{ text_color }};
    --ps-border-radius: {% if section.settings.border_radius %}24px{% else %}0px{% endif %};
    --ps-padding-y: {{ section.settings.padding_y }}px;
    background-color: var(--color-background);
  }

  .ps-container {
    display: block;
    position: relative;
    width: 100%;
    max-width: {% if section.settings.container_width == 'full' %}100%{% elsif section.settings.container_width == 'narrow' %}1000px{% else %}1440px{% endif %};
    margin: 0 auto;
    border-radius: var(--ps-border-radius);
    background-color: var(--ps-bg-color);
    color: var(--ps-text-color);
    overflow: hidden;
    padding: var(--ps-padding-y) 5%;
  }

  /* Backgrounds */
  .ps-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  .ps-bg--gradient { background: linear-gradient(135deg, var(--ps-bg-color) 0%, var(--ps-accent-color) 100%); }
  .ps-bg--mesh {
    background-color: var(--ps-bg-color);
    background-image: 
      radial-gradient(at 0% 0%, var(--ps-accent-color) 0px, transparent 50%),
      radial-gradient(at 100% 100%, var(--ps-accent-color) 0px, transparent 50%);
    background-size: 200% 200%;
    animation: psMesh 10s ease infinite alternate;
  }
  @keyframes psMesh { 0% { background-position: 0% 0%; } 100% { background-position: 100% 100%; } }
  .ps-bg--noise::after {
    content: "";
    position: absolute;
    inset: 0;
    background-image: url('data:image/svg+xml,%3Csvg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"%3E%3Cfilter id="noiseFilter"%3E%3CfeTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/%3E%3C/filter%3E%3Crect width="100%25" height="100%25" filter="url(%23noiseFilter)" opacity="0.05"/%3E%3C/svg%3E');
    opacity: 0.5;
  }

  /* Decorations */
  .ps-decor {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .ps-decor--circle::before {
    content: '';
    width: 60vh;
    height: 60vh;
    background: var(--ps-accent-color);
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.3;
  }
  .ps-decor--grid {
    background-image: linear-gradient(rgba(0,0,0,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(0,0,0,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(circle at center, black 40%, transparent 80%);
    -webkit-mask-image: radial-gradient(circle at center, black 40%, transparent 80%);
  }

  /* Layout */
  .ps-layout {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  @media (min-width: 992px) {
    .ps-layout {
      flex-direction: row;
      gap: 80px;
    }
  }

  /* Media Column */
  .ps-media-col {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }
  @media (min-width: 992px) {
    .ps-media-col {
      position: sticky;
      top: 100px;
      height: calc(100vh - 200px);
      align-items: flex-start;
    }
  }

  .ps-media-wrapper {
    position: relative;
    width: 100%;
    max-width: 500px;
    will-change: transform;
    transition: transform 0.2s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ps-media__image {
    width: 100%;
    height: auto;
    object-fit: contain;
    filter: drop-shadow(0px 20px 40px rgba(0,0,0,0.15));
  }
  .ps-media-wrapper.is-floating {
    animation: psFloat 6s ease-in-out infinite;
  }
  @keyframes psFloat {
    0% { transform: translateY(0); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0); }
  }

  /* Content Column */
  .ps-content-col {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 64px;
    padding-bottom: 40px;
  }

  /* Story Block */
  .ps-story {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  .ps-story__eyebrow {
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 600;
    opacity: 0.7;
  }
  .ps-story__heading {
    font-size: clamp(32px, 5vw, 64px);
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.02em;
    margin: 0;
  }
  .ps-story__desc {
    font-size: clamp(16px, 2vw, 20px);
    line-height: 1.6;
    opacity: 0.85;
    max-width: 500px;
  }

  /* Features Container */
  .ps-features {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .ps-feature-chip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 8px 16px;
    border-radius: 100px;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(0,0,0,0.05);
    font-size: 14px;
    font-weight: 500;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .ps-feature-chip svg {
    width: 16px;
    height: 16px;
    opacity: 0.7;
  }

  /* Metrics Container */
  .ps-metrics {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
  }
  .ps-metric-card {
    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(0,0,0,0.05);
    padding: 24px;
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  .ps-metric-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  .ps-metric__icon {
    font-size: 24px;
    margin-bottom: 8px;
  }
  .ps-metric__value {
    font-size: 24px;
    font-weight: 700;
    line-height: 1;
  }
  .ps-metric__label {
    font-size: 13px;
    opacity: 0.7;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Process / Timeline */
  .ps-process {
    display: flex;
    flex-direction: column;
    gap: 32px;
    position: relative;
    padding-left: 24px;
  }
  .ps-process::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background: var(--ps-text-color);
    opacity: 0.1;
  }
  .ps-process-step {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .ps-process-step::before {
    content: '';
    position: absolute;
    left: -22px;
    top: 6px;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--ps-bg-color);
    border: 2px solid var(--ps-text-color);
    z-index: 2;
  }
  .ps-process-step__title {
    font-size: 18px;
    font-weight: 600;
  }
  .ps-process-step__desc {
    font-size: 14px;
    opacity: 0.7;
    line-height: 1.5;
  }

  /* Reveal Animations */
  .ps-reveal {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .ps-reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Handle Presets */
  .ps-preset-dark {
    .ps-feature-chip { background: rgba(255,255,255,0.05); border-color: rgba(255,255,255,0.1); }
    .ps-metric-card { background: rgba(255,255,255,0.03); border-color: rgba(255,255,255,0.1); }
  }
  
  /* Reduced Motion */
  @media (prefers-reduced-motion: reduce) {
    .ps-reveal { opacity: 1; transform: none; transition: none; }
    .ps-media-wrapper.is-floating { animation: none; }
    .ps-bg--mesh { animation: none; }
  }
{%- endstyle -%}

<product-story-section 
  class="ps-container {% if bg_color == '#000000' or bg_color == '#111111' %}ps-preset-dark{% endif %}"
  data-parallax="{{ section.settings.enable_mouse_parallax }}"
>
  <div class="ps-bg ps-bg--{{ bg_type }}"></div>
  {% if decor_style != 'none' %}
    <div class="ps-decor ps-decor--{{ decor_style }}"></div>
  {% endif %}

  <div class="ps-layout">
    
    <!-- Media Column (Sticky) -->
    <div class="ps-media-col">
      {% if media_block %}
        <div class="ps-media-wrapper {% if section.settings.enable_floating_image %}is-floating{% endif %}" {{ media_block.shopify_attributes }}>
          {% if media_block.settings.image %}
            <img 
              src="{{ media_block.settings.image | image_url: width: 1000 }}" 
              alt="{{ media_block.settings.image.alt | escape }}"
              class="ps-media__image ps-reveal"
              loading="lazy"
            >
          {% else %}
            {{ 'product-1' | placeholder_svg_tag: 'ps-media__image ps-reveal' }}
          {% endif %}
        </div>
      {% endif %}
    </div>

    <!-- Content Column (Scrolls) -->
    <div class="ps-content-col">
      
      {% for block in section.blocks %}
        {% case block.type %}
          
          {% when 'story' %}
            <div class="ps-story ps-reveal" {{ block.shopify_attributes }}>
              {% if block.settings.eyebrow != blank %}
                <div class="ps-story__eyebrow">{{ block.settings.eyebrow | escape }}</div>
              {% endif %}
              {% if block.settings.headline != blank %}
                <h2 class="ps-story__heading font-serif">{{ block.settings.headline | escape }}</h2>
              {% endif %}
              {% if block.settings.description != blank %}
                <div class="ps-story__desc">{{ block.settings.description }}</div>
              {% endif %}
              {% if block.settings.btn_text != blank and block.settings.btn_url != blank %}
                <a href="{{ block.settings.btn_url }}" class="ps-content__btn" style="background-color: var(--ps-text-color); color: var(--ps-bg-color); padding: 16px 32px; border-radius: 100px; display: inline-block; font-weight: 600; margin-top: 16px; align-self: flex-start;">
                  {{ block.settings.btn_text | escape }}
                </a>
              {% endif %}
            </div>

          {% when 'feature_list' %}
            <div class="ps-features ps-reveal" {{ block.shopify_attributes }}>
              {% for i in (1..6) %}
                {% assign feature_key = 'feature_' | append: i %}
                {% assign feature_text = block.settings[feature_key] %}
                {% if feature_text != blank %}
                  <div class="ps-feature-chip">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>
                    {{ feature_text | escape }}
                  </div>
                {% endif %}
              {% endfor %}
            </div>

          {% when 'metrics_container' %}
            <div class="ps-metrics ps-reveal" {{ block.shopify_attributes }}>
              {% for i in (1..4) %}
                {% assign emoji_key = 'metric_emoji_' | append: i %}
                {% assign val_key = 'metric_val_' | append: i %}
                {% assign label_key = 'metric_label_' | append: i %}
                
                {% if block.settings[val_key] != blank %}
                  <div class="ps-metric-card">
                    <div class="ps-metric__icon">{{ block.settings[emoji_key] }}</div>
                    <div class="ps-metric__value font-serif">{{ block.settings[val_key] | escape }}</div>
                    <div class="ps-metric__label">{{ block.settings[label_key] | escape }}</div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

          {% when 'process_timeline' %}
            <div class="ps-process ps-reveal" {{ block.shopify_attributes }}>
              {% for i in (1..5) %}
                {% assign title_key = 'step_title_' | append: i %}
                {% assign desc_key = 'step_desc_' | append: i %}
                
                {% if block.settings[title_key] != blank %}
                  <div class="ps-process-step">
                    <div class="ps-process-step__title">{{ block.settings[title_key] | escape }}</div>
                    {% if block.settings[desc_key] != blank %}
                      <div class="ps-process-step__desc">{{ block.settings[desc_key] | escape }}</div>
                    {% endif %}
                  </div>
                {% endif %}
              {% endfor %}
            </div>

        {% endcase %}
      {% endfor %}

    </div>
  </div>
</product-story-section>

<script>
  if (!customElements.get('product-story-section')) {
    class ProductStorySection extends HTMLElement {
      constructor() {
        super();
        this.reveals = Array.from(this.querySelectorAll('.ps-reveal'));
        this.mediaWrapper = this.querySelector('.ps-media-wrapper');
        this.parallaxEnabled = this.dataset.parallax === 'true';
        this.init();
      }
      
      init() {
        // Intersection Observer for scroll animations
        if ('IntersectionObserver' in window) {
          const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target); // Reveal only once
              }
            });
          }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
          
          this.reveals.forEach(el => observer.observe(el));
        } else {
          this.reveals.forEach(el => el.classList.add('is-visible'));
        }

        // Mouse Parallax Effect
        if (this.parallaxEnabled && this.mediaWrapper && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          this.addEventListener('mousemove', (e) => {
            const rect = this.getBoundingClientRect();
            const x = (e.clientX - rect.left) / rect.width - 0.5;
            const y = (e.clientY - rect.top) / rect.height - 0.5;
            
            this.mediaWrapper.style.transform = `translate(${x * -30}px, ${y * -30}px) rotate(${x * 5}deg)`;
          });
          
          this.addEventListener('mouseleave', () => {
            this.mediaWrapper.style.transform = `translate(0, 0) rotate(0deg)`;
          });
        }
      }
    }
    customElements.define('product-story-section', ProductStorySection);
  }
</script>

{% schema %}
{
  "name": "Product Story",
  "settings": [
    {
      "type": "select",
      "id": "container_width",
      "label": "Container Width",
      "options": [
