<header class="site-header" role="banner">
  <div class="container site-header__inner">

    <!-- Logo -->
    <a
      href="{{ routes.root_url }}"
      class="site-header__logo"
      aria-label="{{ section.settings.logo_text | escape }} — Home"
    >
      {%- if section.settings.logo_image != blank -%}
        <img
          src="{{ section.settings.logo_image | image_url: height: 48 }}"
          alt="{{ section.settings.logo_text | escape }}"
          height="48"
          loading="eager"
        >
      {%- else -%}
        {{ section.settings.logo_text | escape }}
      {%- endif -%}
    </a>

    <!-- Desktop Nav -->
    <nav class="site-header__nav" aria-label="Primary navigation">
      {%- for block in section.blocks -%}
        {%- if block.type == 'nav_link' -%}
          <a
            href="{{ block.settings.url | escape }}"
            class="site-header__nav-link{% if block.settings.accent %} site-header__nav-link--accent{% endif %}"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label | escape }}
          </a>
        {%- endif -%}
      {%- endfor -%}
    </nav>

    <!-- Actions -->
    <div class="site-header__actions">
      <!-- Cart -->
      <button
        class="site-header__action-btn"
        aria-label="Open cart"
        data-cart-open
        id="cart-toggle-btn"
      >
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
          <path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-10 2a2 2 0 100 4 2 2 0 000-4z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span class="cart-count" aria-live="polite" aria-label="Cart item count">
          {{ cart.item_count }}
        </span>
      </button>

      <!-- Account -->
      {%- if shop.customer_accounts_enabled -%}
        <a
          href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
          class="site-header__action-btn"
          aria-label="{%- if customer -%}My account{%- else -%}Log in{%- endif -%}"
        >
          <svg width="22" height="22" viewBox="0 0 22 22" fill="none" aria-hidden="true">
            <path d="M20 21v-2a4 4 0 00-4-4H7a4 4 0 00-4 4v2M11 11a4 4 0 100-8 4 4 0 000 8z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}

      <!-- Mobile Hamburger -->
      <button
        class="site-header__hamburger"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-nav"
      >
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Nav -->
  <nav class="site-header__mobile-nav" id="mobile-nav" aria-label="Mobile navigation">
    {%- for block in section.blocks -%}
      {%- if block.type == 'nav_link' -%}
        <a
          href="{{ block.settings.url | escape }}"
          class="site-header__nav-link{% if block.settings.accent %} site-header__nav-link--accent{% endif %}"
        >
          {{ block.settings.label | escape }}
        </a>
      {%- endif -%}
    {%- endfor -%}

    {%- if shop.customer_accounts_enabled -%}
      <a
        href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
        class="site-header__nav-link"
      >
        {%- if customer -%}My Account{%- else -%}Log In{%- endif -%}
      </a>
    {%- endif -%}
  </nav>
</header>

{% schema %}
{
  "name": "Header",
  "tag": "header",
  "class": "site-header-section",
  "settings": [
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "Artisan3D"
    },
    {
      "type": "image_picker",
      "id": "logo_image",
      "label": "Logo image (overrides text if set)"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Our Process"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "accent",
          "label": "Accent style (Terracotta)",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Our Process", "url": "#process", "accent": false } },
        { "type": "nav_link", "settings": { "label": "The Gallery", "url": "#products", "accent": false } },
        { "type": "nav_link", "settings": { "label": "Pre-order", "url": "#preorder", "accent": true } }
      ]
    }
  ]
}
{% endschema %}
