<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#18241b">

  {%- render 'seo-head' -%}

  {{ content_for_header }}

  {%- liquid
    assign font_url = 'https://fonts.googleapis.com/css2?family=Literata:ital,wght@0,400;0,500;0,600;1,400;1,500;1,600&family=Hanken+Grotesk:wght@400;500;600&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap'
  -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="{{ font_url }}" as="style">
  <link rel="stylesheet" href="{{ font_url }}">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <script>document.documentElement.classList.remove('no-js');</script>
</head>

<body class="template-{{ template.name | handle }}">

  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  {%- sections 'header' -%}

  <!-- Cart Drawer -->
  <div class="cart-overlay" aria-hidden="true"></div>
  <aside class="cart-drawer" role="dialog" aria-label="Shopping cart" aria-modal="true" tabindex="-1">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart</h2>
      <button class="cart-drawer__close" aria-label="Close cart">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="cart-drawer__items">
      <p class="cart-drawer__empty">Your cart is empty.</p>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span class="cart-drawer__subtotal-label">Subtotal</span>
        <span class="cart-drawer__subtotal-value">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="cart-checkout-btn">Proceed to Checkout</a>
    </div>
  </aside>

  <main id="MainContent">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer' -%}

  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
