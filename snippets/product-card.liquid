{% comment %}
  product-card.liquid
  Reusable product card for collection grids (Brutalist).
  @param product {object} - Shopify product object (required)
  @param show_price {boolean} - whether to show price (default true)
{% endcomment %}

{%- liquid
  assign card_product = product
  assign show_price = show_price | default: true
  assign featured_image = card_product.featured_image
  assign product_url = card_product.url | within: collection
  assign product_title = card_product.title | escape
  
  assign handle_exe = card_product.handle | append: ".EXE" | upcase
  assign stock_status = "IN_STOCK"
  if card_product.available == false
    assign stock_status = "OUT_OF_STOCK"
  elsif card_product.inventory_quantity < 5
    assign stock_status = "LOW_STOCK"
  endif
-%}

<article class="stack-item bg-surface brutalist-border rounded-sm shadow-brutalist flex flex-col overflow-hidden reveal" data-product-id="{{ card_product.id }}">
  <!-- Top Bar -->
  <div class="bg-text-dark text-surface px-2 py-1 flex justify-between items-center border-b-3 border-text-dark">
    <span class="font-mono text-xs font-bold">{{ handle_exe | truncate: 20 }}</span>
    <span class="material-symbols-outlined text-sm">close</span>
  </div>

  <div class="p-3 flex flex-col flex-1">
    <!-- Image Window -->
    <a href="{{ product_url }}" class="block brutalist-border rounded-sm overflow-hidden mb-3 aspect-square md:aspect-video bg-background-light relative group" aria-label="{{ product_title }}">
      {%- if featured_image -%}
        <img
          class="w-full h-full object-cover threshold-filter transition-transform duration-300 group-hover:scale-105"
          src="{{ featured_image | image_url: width: 600 }}"
          alt="{{ featured_image.alt | default: product_title | escape }}"
          width="600"
          height="600"
          loading="lazy"
        >
      {%- else -%}
        <div class="w-full h-full flex items-center justify-center text-text-dark font-mono font-bold">NO_IMAGE</div>
      {%- endif -%}
    </a>

    <!-- Details -->
    <div class="flex justify-between items-start mb-4 gap-4 flex-1">
      <div>
        <h3 class="font-display font-bold text-lg uppercase leading-tight">
          <a href="{{ product_url }}" class="hover:underline">{{ product_title }}</a>
        </h3>
        <p class="font-mono text-xs mt-1 {% if stock_status == 'OUT_OF_STOCK' %}text-error{% else %}text-text-dark{% endif %}">
          STATUS: {{ stock_status }}
        </p>
      </div>
      
      {%- if show_price -%}
        <span class="font-mono font-bold text-lg shrink-0">
          {%- if card_product.price_varies -%}
            From {{ card_product.price_min | money }}
          {%- else -%}
            {{ card_product.price | money }}
          {%- endif -%}
        </span>
      {%- else -%}
        <span class="font-mono font-bold text-xs shrink-0 bg-primary px-1 brutalist-border">PREORDER</span>
      {%- endif -%}
    </div>

    <!-- Action -->
    <a href="{{ product_url }}" class="btn-brutalist w-full text-center block bg-cyan-accent brutalist-border shadow-brutalist rounded-sm py-3 font-display font-bold uppercase tracking-wider text-text-dark hover:bg-surface transition-colors mt-auto">
      VIEW_SPECS
    </a>
  </div>
</article>
