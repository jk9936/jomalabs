<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}" class="no-js">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#18241b">

  {%- render 'seo-head' -%}

  {{ content_for_header }}

  {%- liquid
    assign font_url = 'https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;700&family=JetBrains+Mono:wght@400;700&family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap'
  -%}

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="preload" href="{{ font_url }}" as="style">
  <link rel="stylesheet" href="{{ font_url }}">

  {{ 'theme.css' | asset_url | stylesheet_tag }}

  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "primary": "#f2cc0d",
            "background-light": "#EAEAEA",
            "background-dark": "#221f10",
            "surface": "#FFFFFF",
            "text-dark": "#000000",
            "cyan-accent": "#00FFFF",
            "magenta-accent": "#FF00FF",
          },
          fontFamily: {
            "display": ["Space Grotesk", "sans-serif"],
            "mono": ["JetBrains Mono", "monospace"]
          },
          borderRadius: {"DEFAULT": "0.125rem", "sm": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
          boxShadow: {
            'brutalist': '4px 4px 0px 0px #000000',
            'brutalist-hover': '2px 2px 0px 0px #000000',
            'brutalist-active': '0px 0px 0px 0px #000000',
          }
        },
      },
    }
  </script>

  <script>document.documentElement.classList.remove('no-js');</script>
</head>

<body class="bg-transparent min-h-screen flex flex-col pt-16 template-{{ template.name | handle }}">

  <!-- Global Video Background -->
  <video id="main-bg-video" autoplay loop muted playsinline class="fixed inset-0 w-full h-full object-cover z-[-1]">
    <source src="{{ 'main_bg_video_new.mp4' | asset_url }}" type="video/mp4">
  </video>

  {%- sections 'header' -%}

  <!-- Cart Drawer -->
  <div class="cart-overlay" aria-hidden="true"></div>
  <aside class="cart-drawer" role="dialog" aria-label="Shopping cart" aria-modal="true" tabindex="-1">
    <div class="cart-drawer__header">
      <h2 class="cart-drawer__title">Your Cart</h2>
      <button class="cart-drawer__close" aria-label="Close cart">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M15 5L5 15M5 5l10 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
      </button>
    </div>
    <div class="cart-drawer__items">
      <p class="cart-drawer__empty">Your cart is empty.</p>
    </div>
    <div class="cart-drawer__footer">
      <div class="cart-drawer__subtotal">
        <span class="cart-drawer__subtotal-label">Subtotal</span>
        <span class="cart-drawer__subtotal-value">{{ cart.total_price | money }}</span>
      </div>
      <a href="/checkout" class="cart-checkout-btn">Proceed to Checkout</a>
    </div>
  </aside>

  <main id="MainContent" class="flex-1 w-full max-w-7xl mx-auto px-4 pb-20 mt-6 relative z-10">
    {{ content_for_layout }}
  </main>

  {%- sections 'footer' -%}

  {{ 'theme.js' | asset_url | script_tag }}

</body>
</html>
