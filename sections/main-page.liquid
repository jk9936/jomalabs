<div class="max-w-4xl mx-auto px-4 py-16 md:py-24">
  <div class="border-3 border-text-dark bg-surface shadow-brutalist p-8 md:p-12 relative">
    <div class="absolute top-0 left-0 w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between">
      <span class="font-mono text-xs font-bold text-surface">PAGE_READER.EXE</span>
      <div class="flex gap-2">
        <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
        <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
        <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
      </div>
    </div>
    
    <header class="border-b-3 border-text-dark pb-6 mb-8 mt-6">
      <h1 class="font-display font-bold text-4xl md:text-6xl uppercase leading-none text-text-dark tracking-tight">
        {{ page.title | escape }}
      </h1>
    </header>
    
    <div class="font-mono text-sm md:text-base leading-relaxed text-text-dark prose-brutalist">
      {{ page.content }}
    </div>
  </div>
</div>

<style>
  .prose-brutalist p { margin-bottom: 1.5em; font-weight: 500; }
  .prose-brutalist h1, .prose-brutalist h2, .prose-brutalist h3 {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    text-transform: uppercase;
    margin-top: 2em;
    margin-bottom: 0.5em;
    color: #111;
  }
  .prose-brutalist a {
    color: var(--color-cyan-accent, #00ffff);
    background: #111;
    padding: 2px 4px;
    text-decoration: none;
    font-weight: bold;
  }
  .prose-brutalist a:hover {
    color: #111;
    background: var(--color-cyan-accent, #00ffff);
  }
</style>

{% schema %}
{
  "name": "Page Content",
  "settings": [],
  "presets": [{ "name": "Page Content" }]
}
{% endschema %}
