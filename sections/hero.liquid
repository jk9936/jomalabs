<style>
  .section-{{ section.id }}-padding {
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  {%- for block in section.blocks -%}
    {%- if block.type == 'headline' or block.type == 'subheading' or block.type == 'text' or block.type == 'marquee' -%}
      .block-{{ block.id }} {
        font-size: {{ block.settings.size_mobile }}px !important;
      }
      @media screen and (min-width: 768px) {
        .block-{{ block.id }} {
          font-size: {{ block.settings.size_desktop }}px !important;
        }
      }
    {%- endif -%}
  {%- endfor -%}
</style>

<section class="relative w-full min-h-[90vh] flex items-center justify-center p-4 overflow-hidden bg-transparent section-{{ section.id }}-padding">
  
  <!-- Hero Window -->
  <div class="rounded-sm relative z-20 mx-auto mt-16 text-text-dark flex flex-col overflow-hidden{% if section.settings.transparent_window %} bg-transparent{% endif %}"
       style="
         max-width: {{ section.settings.window_width }}px;
         border: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};
         box-shadow: 8px 8px 0px 0px {{ section.settings.shadow_color }};
         transform: rotate({{ section.settings.window_rotation }}deg); 
         {% unless section.settings.transparent_window %}background-color: {{ section.settings.window_bg }};{% endunless %}
       ">
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'window_header' -%}
          <!-- Window Header Block -->
          <div class="w-full h-8 flex items-center px-3 justify-between shrink-0" style="background-color: {{ section.settings.header_bg }}; border-bottom: {{ section.settings.border_width }}px solid {{ section.settings.border_color }};" {{ block.shopify_attributes }}>
            <span class="font-mono text-xs font-bold" style="color: {{ section.settings.header_text }};">{{ block.settings.title | escape }}</span>
            <div class="flex gap-2">
              <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
              <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
              <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
            </div>
          </div>
          
        {%- when 'headline' -%}
          <!-- Headline Block -->
          <div class="px-3 sm:px-6 pt-4 pb-1" {{ block.shopify_attributes }}>
            <h2 class="block-{{ block.id }} font-display font-bold uppercase leading-none tracking-tight" style="color: {{ block.settings.text_color }}; text-align: {{ block.settings.alignment }};">
              {{ block.settings.text | newline_to_br }}
            </h2>
          </div>

        {%- when 'subheading' -%}
          <!-- Subheading Block -->
          <div class="px-3 sm:px-6 py-1 flex" style="justify-content: {% if block.settings.alignment == 'center' %}center{% elsif block.settings.alignment == 'right' %}flex-end{% else %}flex-start{% endif %};" {{ block.shopify_attributes }}>
            <span class="block-{{ block.id }} font-mono font-bold uppercase tracking-widest border-2 border-text-dark px-2 sm:px-3 py-1 bg-background-light">
              {{ block.settings.text | escape }}
            </span>
          </div>

        {%- when 'text' -%}
          <!-- Text Block -->
          <div class="px-3 sm:px-6 py-1" {{ block.shopify_attributes }}>
            <p class="block-{{ block.id }} font-mono font-bold text-text-dark" style="text-align: {{ block.settings.alignment }};">
              {% if block.settings.show_prefix %}>>> {% endif %}{{ block.settings.text | escape }}
            </p>
          </div>

        {%- when 'marquee' -%}
          <!-- Marquee Block -->
          <div class="w-full overflow-hidden border-y-3 border-text-dark py-1 my-1 sm:my-2 flex whitespace-nowrap shrink-0" style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};" {{ block.shopify_attributes }}>
            <div class="block-{{ block.id }} animate-marquee inline-block font-display font-bold uppercase tracking-wider shrink-0">
              {{ block.settings.text | escape }} &nbsp;&bull;&nbsp; {{ block.settings.text | escape }} &nbsp;&bull;&nbsp; {{ block.settings.text | escape }} &nbsp;&bull;&nbsp; {{ block.settings.text | escape }} &nbsp;&bull;&nbsp;
            </div>
          </div>

        {%- when 'image' -%}
          <!-- Image Graphic Block -->
          {%- if block.settings.image != blank -%}
            <div class="px-3 sm:px-6 py-2 flex" style="justify-content: {% if block.settings.alignment == 'center' %}center{% elsif block.settings.alignment == 'right' %}flex-end{% else %}flex-start{% endif %};" {{ block.shopify_attributes }}>
              <img
                srcset="
                  {{ block.settings.image | image_url: width: 350 }} 350w,
                  {{ block.settings.image | image_url: width: 550 }} 550w,
                  {{ block.settings.image | image_url: width: 750 }} 750w,
                  {{ block.settings.image | image_url: width: 950 }} 950w,
                  {{ block.settings.image | image_url: width: 1200 }} 1200w,
                  {{ block.settings.image | image_url: width: 1600 }} 1600w
                "
                src="{{ block.settings.image | image_url: width: 800 }}"
                sizes="(max-width: 768px) 100vw, 50vw"
                alt="{{ block.settings.image.alt | default: '' | escape }}" 
                width="{{ block.settings.image.width | default: 800 }}"
                height="{{ block.settings.image.height | default: 600 }}"
                loading="lazy"
                style="max-width: {{ block.settings.image_width }}%;"
                class="object-contain {% if block.settings.add_border %}brutalist-border rounded-sm shadow-brutalist{% endif %}"
              >
            </div>
          {%- endif -%}

        {%- when 'ascii' -%}
          <!-- ASCII Art Block -->
          <div class="px-3 sm:px-6 py-2 flex overflow-hidden" style="justify-content: {% if block.settings.alignment == 'center' %}center{% elsif block.settings.alignment == 'right' %}flex-end{% else %}flex-start{% endif %};" {{ block.shopify_attributes }}>
            <pre class="font-mono leading-none whitespace-pre" style="color: {{ block.settings.text_color }}; font-size: {{ block.settings.size_mobile }}px;">
              {{- block.settings.ascii_text -}}
            </pre>
          </div>


      {%- endcase -%}
    {%- endfor -%}

    <!-- Buttons Container (Group all button blocks together at the bottom if present) -->
    {%- assign button_blocks = section.blocks | where: "type", "button" -%}
    {%- if button_blocks.size > 0 -%}
      <div class="px-3 sm:px-6 pb-4 sm:pb-6 pt-2 flex flex-wrap gap-2 mt-auto">
        {%- for block in button_blocks -%}
          <a href="{{ block.settings.link }}" class="btn-brutalist block sm:inline-block w-full sm:w-auto text-center border-3 border-text-dark shadow-brutalist rounded-sm px-6 py-3 font-display font-bold uppercase tracking-wider transition-colors hover:brightness-90"
             style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};"
             {{ block.shopify_attributes }}>
            {{ block.settings.label | escape }}
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 10s linear infinite;
    min-width: 200%;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

