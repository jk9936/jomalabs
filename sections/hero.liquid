<section class="relative w-full min-h-[90vh] flex items-center justify-center p-4 overflow-hidden border-b-3 border-text-dark bg-background-dark">
  
  <!-- Background Layer -->
  <div class="absolute inset-0 z-0">
    {% if section.settings.bg_video != blank %}
      {{ section.settings.bg_video | video_tag: class: 'w-full h-full object-cover', autoplay: true, loop: true, muted: true, controls: false }}
    {% elsif section.settings.bg_image != blank %}
      {{ section.settings.bg_image | image_url: width: 2400 | image_tag: class: 'w-full h-full object-cover', loading: 'eager' }}
    {% else %}
      <div class="w-full h-full bg-background-light"></div>
    {% endif %}
    <div class="absolute inset-0 bg-text-dark" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
  </div>

  <!-- Hero Window -->
  <div class="brutalist-border rounded-sm shadow-brutalist max-w-2xl w-full relative z-20 mx-auto mt-16 text-text-dark flex flex-col overflow-hidden"
       style="transform: rotate({{ section.settings.window_rotation }}deg); background-color: {{ section.settings.window_bg }};">
    
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'window_header' -%}
          <!-- Window Header Block -->
          <div class="w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between shrink-0" {{ block.shopify_attributes }}>
            <span class="font-mono text-xs font-bold text-surface">{{ block.settings.title | escape }}</span>
            <div class="flex gap-2">
              <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
              <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
              <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
            </div>
          </div>
          
        {%- when 'headline' -%}
          <!-- Headline Block -->
          <div class="px-8 pt-8 pb-4" {{ block.shopify_attributes }}>
            <h2 class="font-display font-bold text-5xl md:text-7xl uppercase leading-none tracking-tight" style="color: {{ block.settings.text_color }}; text-align: {{ block.settings.alignment }};">
              {{ block.settings.text | newline_to_br }}
            </h2>
          </div>

        {%- when 'subheading' -%}
          <!-- Subheading Block -->
          <div class="px-8 py-2 flex" style="justify-content: {% if block.settings.alignment == 'center' %}center{% elsif block.settings.alignment == 'right' %}flex-end{% else %}flex-start{% endif %};" {{ block.shopify_attributes }}>
            <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 bg-background-light">
              {{ block.settings.text | escape }}
            </span>
          </div>

        {%- when 'text' -%}
          <!-- Text Block -->
          <div class="px-8 py-2" {{ block.shopify_attributes }}>
            <p class="font-mono text-sm md:text-base font-bold text-text-dark" style="text-align: {{ block.settings.alignment }};">
              {% if block.settings.show_prefix %}>>> {% endif %}{{ block.settings.text | escape }}
            </p>
          </div>

        {%- when 'marquee' -%}
          <!-- Marquee Block -->
          <div class="w-full overflow-hidden border-y-3 border-text-dark py-2 my-4 flex whitespace-nowrap shrink-0" style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};" {{ block.shopify_attributes }}>
            <div class="animate-marquee inline-block font-display font-bold text-xl uppercase tracking-wider shrink-0">
              {{ block.settings.text | escape }} &nbsp;&bull;&nbsp; {{ block.settings.text | escape }} &nbsp;&bull;&nbsp; {{ block.settings.text | escape }} &nbsp;&bull;&nbsp; {{ block.settings.text | escape }} &nbsp;&bull;&nbsp;
            </div>
          </div>

      {%- endcase -%}
    {%- endfor -%}

    <!-- Buttons Container (Group all button blocks together at the bottom if present) -->
    {%- assign button_blocks = section.blocks | where: "type", "button" -%}
    {%- if button_blocks.size > 0 -%}
      <div class="px-8 pb-8 pt-4 flex flex-wrap gap-4 mt-auto">
        {%- for block in button_blocks -%}
          <a href="{{ block.settings.link }}" class="btn-brutalist inline-block border-3 border-text-dark shadow-brutalist rounded-sm px-6 py-3 font-display font-bold uppercase tracking-wider transition-colors hover:brightness-90"
             style="background-color: {{ block.settings.bg_color }}; color: {{ block.settings.text_color }};"
             {{ block.shopify_attributes }}>
            {{ block.settings.label | escape }}
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  .animate-marquee {
    animation: marquee 10s linear infinite;
    min-width: 200%;
  }
  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>

{% schema %}
{
  "name": "Customizable Hero Window",
  "settings": [
    {
      "type": "header",
      "content": "Canvas Settings"
    },
    {
      "type": "video",
      "id": "bg_video",
      "label": "Background Video (Cinematic Loop)"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Fallback Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Video Overlay Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 30,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Window Settings"
    },
    {
      "type": "color",
      "id": "window_bg",
      "label": "Window Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "range",
      "id": "window_rotation",
      "label": "Window Rotation (deg)",
      "min": -10,
      "max": 10,
      "step": 1,
      "default": -1
    }
  ],
  "blocks": [
    {
      "type": "window_header",
      "name": "Window Header Bar",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Terminal Title",
          "default": "SYSTEM.EXE"
        }
      ]
    },
    {
      "type": "headline",
      "name": "Headline",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "TOOLS FOR\nTHE 10X\nENGINEER."
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#111111"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading Box",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "JOMA LABS"
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "text",
      "name": "Terminal Text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "EXECUTE UPGRADE_WORKSPACE.SH"
        },
        {
          "type": "checkbox",
          "id": "show_prefix",
          "label": "Show '>>>' prefix",
          "default": true
        },
        {
          "type": "select",
          "id": "alignment",
          "label": "Alignment",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "center", "label": "Center" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "type": "button",
      "name": "Button",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Button Label",
          "default": "INITIALIZE"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Button Link"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#2f8dff"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#111111"
        }
      ]
    },
    {
      "type": "marquee",
      "name": "Scrolling Marquee",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Marquee Text",
          "default": "WARNING // SYSTEM OVERRIDE //"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Background Color",
          "default": "#ffdd57"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#111111"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Customizable Hero Window",
      "blocks": [
        { "type": "window_header", "settings": { "title": "JOMA_OS.EXE" } },
        { "type": "subheading", "settings": { "text": "LIMITED RUN" } },
        { "type": "headline", "settings": { "text": "Manifesting\nIdeas in\nreal time," } },
        { "type": "text", "settings": { "text": "Bring main charecter engery to your life with custom and limited 3D prints", "show_prefix": true } },
        { "type": "marquee", "settings": { "text": "WARNING // STOCK EXTREMELY LOW //" } },
        { "type": "button", "settings": { "label": "INITIALIZE", "bg_color": "#2f8dff" } },
        { "type": "button", "settings": { "label": "VIEW SPECS", "bg_color": "#f4f4f4" } }
      ]
    }
  ]
}
{% endschema %}
