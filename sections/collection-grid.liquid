<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
  .collection-grid-wrapper-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    position: relative;
    z-index: 1;
  }
  {%- if section.settings.bg_image != blank -%}
  .collection-grid-wrapper-{{ section.id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-image: url('{{ section.settings.bg_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    opacity: {{ section.settings.bg_image_opacity | divided_by: 100.0 }};
    z-index: -1;
  }
  {%- endif -%}
</style>

<div class="w-full section-{{ section.id }}-padding collection-grid-wrapper-{{ section.id }}">
  <div class="max-w-7xl mx-auto px-4">
    <header class="border-b-3 pb-8 mb-12 flex flex-col items-start gap-4" style="border-color: {{ section.settings.text_color | default: '#111' }};">
      <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 px-3 py-1" style="background-color: {{ section.settings.accent_color }}; border-color: {{ section.settings.text_color | default: '#111' }}; color: #111;">SYSTEM.DIR // {{ section.settings.eyebrow | default: 'COLLECTION' | escape }}</span>
      <h1 class="font-display font-bold text-5xl md:text-7xl uppercase leading-none tracking-tight" style="color: {{ section.settings.text_color }};">
        {%- if collection.title != blank -%}
          {{ collection.title | escape }}
        {%- else -%}
          {{ section.settings.title | escape }}
        {%- endif -%}
      </h1>
      {%- assign coll_desc = collection.description | strip_html | truncate: 200 | default: section.settings.description -%}
      {%- if coll_desc != blank -%}
        <p class="font-mono text-sm md:text-base font-bold max-w-2xl mt-4" style="color: {{ section.settings.text_color }};">>>> {{ coll_desc | escape }}</p>
      {%- endif -%}
    </header>

  {%- if collection.products.size > 0 -%}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="collection-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card',
          product: product,
          show_price: section.settings.show_price,
          image_position_x: section.settings.image_position_x,
          image_position_y: section.settings.image_position_y
        -%}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="mt-16 flex justify-center items-center gap-4 font-mono font-bold uppercase text-sm" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="border-3 border-text-dark px-4 py-2 hover:bg-text-dark hover:text-white transition-colors">&larr; PREV</a>
        {%- endif -%}
        <span class="px-4 py-2 bg-text-dark text-white border-3 border-text-dark">
          PAGE {{ paginate.current_page }} / {{ paginate.pages }}
        </span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="border-3 border-text-dark px-4 py-2 hover:bg-text-dark hover:text-white transition-colors">NEXT &rarr;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- else -%}
    <div class="border-3 p-12 text-center shadow-brutalist mt-12" style="background-color: {{ section.settings.accent_color }}; border-color: {{ section.settings.text_color | default: '#111' }};">
      <p class="font-mono text-xl font-bold uppercase tracking-widest" style="color: #111;">ERR: NO_RECORDS_FOUND</p>
      <p class="font-mono text-sm font-bold mt-2" style="color: #111;">No products exist in this directory.</p>
    </div>
  {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Gallery"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Fallback Title",
      "default": "All Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback Description"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show Price",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "transparent"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "bg_image_opacity",
      "label": "Background Image Opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text & Border Color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Badges/Errors)",
      "default": "#ffdd57"
    },
    {
      "type": "range",
      "id": "image_position_x",
      "label": "Image Focal Point (Horizontal %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "range",
      "id": "image_position_y",
      "label": "Image Focal Point (Vertical %)",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 50
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}
