<div class="max-w-7xl mx-auto px-4 py-16">
  <header class="border-b-3 border-text-dark pb-8 mb-12 flex flex-col items-start gap-4">
    <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 bg-background-light">SYSTEM.DIR // {{ section.settings.eyebrow | default: 'COLLECTION' | escape }}</span>
    <h1 class="font-display font-bold text-5xl md:text-7xl uppercase leading-none tracking-tight text-text-dark">
      {%- if collection.title != blank -%}
        {{ collection.title | escape }}
      {%- else -%}
        {{ section.settings.title | escape }}
      {%- endif -%}
    </h1>
    {%- assign coll_desc = collection.description | strip_html | truncate: 200 | default: section.settings.description -%}
    {%- if coll_desc != blank -%}
      <p class="font-mono text-sm md:text-base font-bold text-text-dark max-w-2xl mt-4">>>> {{ coll_desc | escape }}</p>
    {%- endif -%}
  </header>

  {%- if collection.products.size > 0 -%}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="collection-grid">
      {%- for product in collection.products -%}
        {%- render 'product-card',
          product: product,
          show_price: section.settings.show_price
        -%}
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <nav class="mt-16 flex justify-center items-center gap-4 font-mono font-bold uppercase text-sm" aria-label="Pagination">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="border-3 border-text-dark px-4 py-2 hover:bg-text-dark hover:text-white transition-colors">&larr; PREV</a>
        {%- endif -%}
        <span class="px-4 py-2 bg-text-dark text-white border-3 border-text-dark">
          PAGE {{ paginate.current_page }} / {{ paginate.pages }}
        </span>
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="border-3 border-text-dark px-4 py-2 hover:bg-text-dark hover:text-white transition-colors">NEXT &rarr;</a>
        {%- endif -%}
      </nav>
    {%- endif -%}
  {%- else -%}
    <div class="border-3 border-text-dark bg-yellow-accent p-12 text-center shadow-brutalist mt-12">
      <p class="font-mono text-xl font-bold uppercase tracking-widest text-text-dark">ERR: NO_RECORDS_FOUND</p>
      <p class="font-mono text-sm font-bold mt-2">No products exist in this directory.</p>
    </div>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Collection Grid",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "The Gallery"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Fallback Title",
      "default": "All Products"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Fallback Description"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show Price",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Collection Grid"
    }
  ]
}
{% endschema %}
