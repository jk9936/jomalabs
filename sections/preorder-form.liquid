<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

<section class="max-w-4xl mx-auto px-4 section-{{ section.id }}-padding relative z-20" id="preorder">
  <div class="bg-surface brutalist-border rounded-sm shadow-brutalist p-8 md:p-12 relative overflow-hidden">
    <!-- UI Window Bar -->
    <div class="absolute top-0 left-0 w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between">
      <span class="font-mono text-xs font-bold text-surface">PREORDER_SYSTEM.EXE</span>
      <div class="flex gap-2">
        <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
        <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
        <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
      </div>
    </div>

    <div class="mt-8 mb-10 text-center flex flex-col items-center">
      <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 mb-4 bg-background-light">{{ section.settings.eyebrow | escape }}</span>
      <h2 class="font-display font-bold text-4xl md:text-5xl uppercase leading-none mb-4">{{ section.settings.title | newline_to_br }}</h2>
      {%- if section.settings.quote != blank -%}
        <p class="font-mono text-sm max-w-lg mx-auto font-bold mt-2 text-text-dark">>>> {{ section.settings.quote | escape }}</p>
      {%- endif -%}
    </div>

    <div id="preorder-flash" data-preorder-flash style="display:none" role="alert"></div>

    {%- form 'contact', id: 'preorder-contact-form', data-preorder-form: '' -%}
      <input type="hidden" name="contact[tags]" value="preorder">

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
        <!-- Name -->
        <div class="flex flex-col">
          <label class="font-mono text-xs font-bold uppercase tracking-wider mb-2" for="preorder-name">NAME_INPUT</label>
          <input
            class="brutalist-border rounded-sm bg-background-light p-3 font-mono text-sm focus:outline-none focus:bg-white focus:ring-0 transition-colors placeholder:text-text-dark/50"
            type="text"
            id="preorder-name"
            name="contact[name]"
            placeholder="[ ENTER IDENTIFIER ]"
            autocomplete="name"
            required
          >
        </div>

        <!-- Email -->
        <div class="flex flex-col">
          <label class="font-mono text-xs font-bold uppercase tracking-wider mb-2" for="preorder-email">NETWORK_ADDRESS</label>
          <input
            class="brutalist-border rounded-sm bg-background-light p-3 font-mono text-sm focus:outline-none focus:bg-white focus:ring-0 transition-colors placeholder:text-text-dark/50"
            type="email"
            id="preorder-email"
            name="contact[email]"
            placeholder="[ ENTER EMAIL ]"
            autocomplete="email"
            required
          >
        </div>
      </div>

      <div class="flex flex-col mb-8">
        <label class="font-mono text-xs font-bold uppercase tracking-wider mb-2" for="preorder-mobile">COMMUNICATION_LINK (MOBILE)</label>
        <div class="flex gap-2">
          <select class="brutalist-border rounded-sm bg-background-light p-3 font-mono text-sm focus:outline-none focus:bg-white w-32 cursor-pointer shrink-0" id="preorder-country-code" name="contact[country_code]" aria-label="Country Code" required>
            <option value="+91" selected>+91</option>
            <option value="+1">+1</option>
            <option value="+44">+44</option>
            <option value="+61">+61</option>
            <option value="+81">+81</option>
            <option value="+49">+49</option>
            <option value="+33">+33</option>
            <option value="+39">+39</option>
            <option value="+34">+34</option>
            <option value="+55">+55</option>
            <option value="+86">+86</option>
          </select>
          <input
            class="brutalist-border rounded-sm bg-background-light p-3 font-mono text-sm focus:outline-none focus:bg-white focus:ring-0 transition-colors placeholder:text-text-dark/50 flex-1"
            type="tel"
            id="preorder-mobile"
            name="contact[mobile]"
            placeholder="[ DIGITS ONLY ]"
            autocomplete="tel"
            pattern="[0-9]{7,15}"
            title="Please enter a valid phone number without spaces or dashes (7 to 15 digits)"
            required
          >
        </div>
      </div>

      <button type="submit" class="btn-brutalist w-full bg-cyan-accent brutalist-border shadow-brutalist rounded-sm py-4 font-display font-bold text-lg uppercase tracking-wider text-text-dark hover:bg-surface transition-colors" id="preorder-submit-btn">
        {{ section.settings.submit_label | escape }}
      </button>
      
      <div class="preorder__success mt-4 bg-primary brutalist-border p-4 text-center hidden" role="alert" aria-live="polite">
        <p class="font-mono text-sm font-bold">SYSTEM_MSG: {{ section.settings.success_message | escape }}</p>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Pre-order Form",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label",
      "default": "An Invitation"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Join the Next\nPrint Run"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote / subtext",
      "default": "Our machines run on a deliberate schedule to ensure uncompromising quality. We invite you to reserve your place in our upcoming batch."
    },
    {
      "type": "text",
      "id": "submit_label",
      "label": "Submit button label",
      "default": "Seal the Request"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Your request has been received. We will be in touch soon."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 144
    }
  ],
  "blocks": [
    {
      "type": "product_option",
      "name": "Product option",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Option label",
          "default": "Celestial Serpent"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pre-order Form",
      "blocks": [
        { "type": "product_option", "settings": { "label": "Celestial Serpent" } },
        { "type": "product_option", "settings": { "label": "Kraken Grip" } },
        { "type": "product_option", "settings": { "label": "Primal Echo (Skull)" } },
        { "type": "product_option", "settings": { "label": "Custom Commission" } }
      ]
    }
  ]
}
{% endschema %}
