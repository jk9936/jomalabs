<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

<section class="max-w-7xl mx-auto px-4 section-{{ section.id }}-padding" id="products" aria-label="Product showcase">
  <div class="flex flex-col gap-16 md:gap-24">
    {%- for block in section.blocks -%}
      {%- if block.type == 'product_item' -%}
        {%- liquid
          assign showcase_product = block.settings.product
          assign is_reverse = forloop.index0 | modulo: 2 | equals: 1
          assign title = block.settings.custom_title | default: showcase_product.title
          assign body = block.settings.custom_description | default: showcase_product.description | strip_html | truncate: 280
          assign image = block.settings.custom_image | default: showcase_product.featured_image
          assign product_url = showcase_product.url | default: '#'
        -%}

        <article
          class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-center"
          id="product-{{ block.id }}"
          {{ block.shopify_attributes }}
        >
          <!-- Image -->
          <div class="border-3 border-text-dark shadow-brutalist bg-surface overflow-hidden {% if is_reverse %}lg:order-2{% endif %}">
            <div class="w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between shrink-0">
              <span class="font-mono text-xs font-bold text-surface">IMG_RENDER.EXE</span>
              <div class="flex gap-2">
                <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
                <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
              </div>
            </div>
            {%- if image != blank -%}
              <style>
                #product-{{ block.id }} .showcase-img {
                  height: {{ block.settings.image_height_mobile }}px;
                  object-position: {{ block.settings.image_position }};
                }
                @media (min-width: 1024px) {
                  #product-{{ block.id }} .showcase-img {
                    height: {{ block.settings.image_height_desktop }}px;
                  }
                }
              </style>
              <img
                class="showcase-img w-full object-cover filter hover:brightness-110 transition-all"
                src="{{ image | image_url: width: 1200 }}"
                alt="{{ image.alt | default: title | escape }}"
                width="1200"
                height="900"
                loading="lazy"
              >
            {%- endif -%}
          </div>

          <!-- Content -->
          <div class="flex flex-col gap-6 {% if is_reverse %}lg:order-1{% endif %}">
            <!-- Material chips -->
            {%- assign chip_tags = block.settings.chips | split: ',' -%}
            {%- if chip_tags.size > 0 and block.settings.chips != blank -%}
              <div class="flex flex-wrap gap-2">
                {%- for chip in chip_tags -%}
                  <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 bg-yellow-accent text-text-dark">
                    [{{ chip | strip | escape }}]
                  </span>
                {%- endfor -%}
              </div>
            {%- elsif showcase_product != blank -%}
              <div class="flex flex-wrap gap-2">
                {%- for tag in showcase_product.tags limit: 3 -%}
                  <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 bg-yellow-accent text-text-dark">
                    [{{ tag | escape }}]
                  </span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <!-- Title -->
            <h3 class="font-display font-bold text-4xl md:text-5xl uppercase leading-none text-text-dark">
              {{ title | escape }}
            </h3>

            <!-- Description -->
            {%- if body != blank -%}
              <p class="font-mono text-sm md:text-base font-bold text-text-dark border-l-4 border-text-dark pl-4">
                >>> {{ body | escape }}
              </p>
            {%- endif -%}

            <!-- Spec list (optional) -->
            {%- if block.settings.spec_1_label != blank or block.settings.spec_2_label != blank -%}
              <div class="border-t-3 border-text-dark pt-4 mt-2 flex flex-col gap-2">
                {%- if block.settings.spec_1_label != blank -%}
                  <div class="flex justify-between bg-text-dark text-white p-3 font-mono text-xs font-bold uppercase tracking-wider">
                    <span>{{ block.settings.spec_1_label | escape }}</span>
                    <span class="text-cyan-accent">{{ block.settings.spec_1_value | escape }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.spec_2_label != blank -%}
                  <div class="flex justify-between bg-text-dark text-white p-3 font-mono text-xs font-bold uppercase tracking-wider">
                    <span>{{ block.settings.spec_2_label | escape }}</span>
                    <span class="text-cyan-accent">{{ block.settings.spec_2_value | escape }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.spec_3_label != blank -%}
                  <div class="flex justify-between bg-text-dark text-white p-3 font-mono text-xs font-bold uppercase tracking-wider">
                    <span>{{ block.settings.spec_3_label | escape }}</span>
                    <span class="text-cyan-accent">{{ block.settings.spec_3_value | escape }}</span>
                  </div>
                {%- endif -%}
              </div>
            {%- endif -%}

            <!-- CTA -->
            {%- if showcase_product != blank or block.settings.cta_url != blank -%}
              {%- assign cta_href = block.settings.cta_url | default: product_url | escape -%}
              <a href="{{ cta_href }}" class="btn-brutalist inline-block border-3 border-text-dark shadow-brutalist rounded-sm px-6 py-4 font-display font-bold text-lg uppercase tracking-wider text-text-dark bg-cyan-accent hover:bg-surface w-fit mt-4 transition-colors">
                {{ block.settings.cta_label | default: 'View Details' | escape }} &rarr;
              </a>
            {%- endif -%}

          </div>
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Product Showcase",
  "settings": [
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "product_item",
      "name": "Featured Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
          "type": "header",
          "content": "Overrides (Optional)"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom Image (override product image)"
        },
        {
          "type": "header",
          "content": "Image Controls"
        },
        {
          "type": "range",
          "id": "image_height_desktop",
          "label": "Desktop Image Height",
          "min": 200,
          "max": 1000,
          "step": 10,
          "default": 500
        },
        {
          "type": "range",
          "id": "image_height_mobile",
          "label": "Mobile Image Height",
          "min": 200,
          "max": 800,
          "step": 10,
          "default": 400
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image Position",
          "options": [
            { "value": "top left", "label": "Top Left" },
            { "value": "top center", "label": "Top Center" },
            { "value": "top right", "label": "Top Right" },
            { "value": "center left", "label": "Center Left" },
            { "value": "center center", "label": "Center Center" },
            { "value": "center right", "label": "Center Right" },
            { "value": "bottom left", "label": "Bottom Left" },
            { "value": "bottom center", "label": "Bottom Center" },
            { "value": "bottom right", "label": "Bottom Right" }
          ],
          "default": "center center"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom Title"
        },
        {
          "type": "textarea",
          "id": "custom_description",
          "label": "Custom Description"
        },
        {
          "type": "text",
          "id": "chips",
          "label": "Custom Tags (comma separated)",
          "info": "Leave blank to use product tags"
        },
        {
          "type": "header",
          "content": "Call to Action"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Button Label",
          "default": "View Artifact"
        },
        {
          "type": "url",
          "id": "cta_url",
          "label": "Custom Button Link (overrides product url)"
        },
        {
          "type": "header",
          "content": "Spec List"
        },
        {
          "type": "text",
          "id": "spec_1_label",
          "label": "Spec 1 Label"
        },
        {
          "type": "text",
          "id": "spec_1_value",
          "label": "Spec 1 Value"
        },
        {
          "type": "text",
          "id": "spec_2_label",
          "label": "Spec 2 Label"
        },
        {
          "type": "text",
          "id": "spec_2_value",
          "label": "Spec 2 Value"
        },
        {
          "type": "text",
          "id": "spec_3_label",
          "label": "Spec 3 Label"
        },
        {
          "type": "text",
          "id": "spec_3_value",
          "label": "Spec 3 Value"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Showcase List",
      "blocks": [
        { "type": "product_item" },
        { "type": "product_item" }
      ]
    }
  ]
}
{% endschema %}
