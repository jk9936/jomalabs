<style>
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 768px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
</style>

<section class="max-w-7xl mx-auto px-4 section-{{ section.id }}-padding" id="process">
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

    <!-- Sidebar -->
    <div class="lg:col-span-4 flex flex-col gap-6">
      <div class="w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between">
        <span class="font-mono text-xs font-bold text-surface">SYS.PROCESS</span>
        <div class="flex gap-2">
          <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
          <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
          <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
        </div>
      </div>
      
      <div class="border-3 border-text-dark p-6 bg-yellow-accent shadow-brutalist">
        <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 bg-background-light mb-4 inline-block">
          [{{ section.settings.chapter_label | escape }}]
        </span>
        <h2 class="font-display font-bold text-4xl md:text-5xl uppercase leading-none text-text-dark mb-4">
          {{ section.settings.title | escape }}
          {%- if section.settings.title_italic != blank -%}
            <br><span class="text-white bg-text-dark px-2">{{ section.settings.title_italic | escape }}</span>
          {%- endif -%}
        </h2>
        {%- if section.settings.description != blank -%}
          <p class="font-mono text-sm font-bold text-text-dark border-l-4 border-text-dark pl-4 bg-background-light py-2">
            >>> {{ section.settings.description | escape }}
          </p>
        {%- endif -%}
      </div>
    </div>

    <!-- Steps -->
    <div class="lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-6">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <div class="border-3 border-text-dark bg-surface shadow-brutalist p-6 flex flex-col h-full hover:bg-cyan-accent transition-colors group" {{ block.shopify_attributes }}>
            <div class="font-display font-bold text-5xl text-text-dark mb-4 opacity-50 group-hover:opacity-100 transition-opacity border-b-3 border-text-dark pb-2">
              {{ forloop.index | prepend: '0' | slice: -2, 2 }}
            </div>
            <div class="flex-grow pt-2">
              <h3 class="font-display font-bold text-2xl uppercase text-text-dark mb-3 flex items-center gap-2">
                {%- if block.settings.icon != blank -%}
                  {%- render 'icon', icon_name: block.settings.icon, icon_class: 'text-3xl' -%}
                {%- endif -%}
                {{ block.settings.title | escape }}
              </h3>
              {%- if block.settings.description != blank -%}
                <p class="font-mono text-sm font-bold text-text-dark opacity-80 group-hover:opacity-100 transition-opacity">
                  {{ block.settings.description | escape }}
                </p>
              {%- endif -%}
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Process",
  "settings": [
    {
      "type": "text",
      "id": "chapter_label",
      "label": "Chapter label",
      "default": "Chapter 01"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "The Artisanal"
    },
    {
      "type": "text",
      "id": "title_italic",
      "label": "Title — italic accent",
      "default": "Process"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "A dedication to craft in the digital age. We don't just print; we sculpt with light and resin."
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 96
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Step title",
          "default": "Precision Slicing"
        },
        {
          "type": "text",
          "id": "icon",
          "label": "Material Symbol icon name",
          "info": "Find icon names at fonts.google.com/icons — e.g. precision_manufacturing",
          "default": "precision_manufacturing"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Step description",
          "default": "Every model is meticulously prepared to balance structural integrity with flawless surface detail."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Process Steps",
      "blocks": [
        { "type": "step", "settings": { "title": "Precision Slicing", "icon": "precision_manufacturing" } },
        { "type": "step", "settings": { "title": "Resin Curation", "icon": "water_drop" } },
        { "type": "step", "settings": { "title": "Controlled Curing", "icon": "lightbulb" } },
        { "type": "step", "settings": { "title": "Hand Finishing", "icon": "brush" } }
      ]
    }
  ]
}
{% endschema %}
