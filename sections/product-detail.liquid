{%- liquid
  assign container_width = section.settings.container_width
  assign layout_split = section.settings.layout_split
  assign gallery_layout = section.settings.gallery_layout
  assign gallery_aspect_ratio = section.settings.gallery_aspect_ratio
  
  assign bg_color = section.settings.bg_color | default: 'var(--color-surface)'
  assign text_color = section.settings.text_color | default: 'var(--color-text-dark)'
-%}

{%- style -%}
  #shopify-section-{{ section.id }} {
    --product-bg: {{ bg_color }};
    --product-text: {{ text_color }};
    background-color: var(--product-bg);
    color: var(--product-text);
  }

  .product-page-wrapper {
    width: 100%;
    padding: 32px 16px 96px;
  }
  @media (min-width: 768px) {
    .product-page-wrapper {
      padding: 48px 32px 128px;
    }
  }

  .product-page__inner {
    margin: 0 auto;
    width: 100%;
  }
  .product-page__inner--narrow { max-width: 1000px; }
  .product-page__inner--standard { max-width: 1440px; }
  .product-page__inner--full { max-width: 100%; padding: 0 2%; }

  .product-page__grid {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }
  
  @media (min-width: 1024px) {
    .product-page__grid {
      flex-direction: row;
      gap: 32px;
      align-items: flex-start;
    }
    
    .product-page__grid--5050 .product-gallery-col { width: 50%; }
    .product-page__grid--5050 .product-info-col { width: 50%; }
    
    .product-page__grid--6040 .product-gallery-col { width: 60%; }
    .product-page__grid--6040 .product-info-col { width: 40%; }
    
    .product-page__grid--6535 .product-gallery-col { width: 65%; }
    .product-page__grid--6535 .product-info-col { width: 35%; }
    
    .product-gallery-col {
      position: sticky;
      top: 100px;
    }
  }

  /* Gallery Media Brutalist */
  .product-media-item {
    width: 100%;
    border: 3px solid #111;
    overflow: hidden;
    background: #fff;
    box-shadow: 6px 6px 0px #111;
    position: relative;
  }
  
  /* System Bar on Images */
  .product-media-item::before {
    content: "IMAGE_DATA.RAW";
    display: flex;
    align-items: center;
    padding: 0 12px;
    width: 100%;
    height: 32px;
    background: #111;
    color: #fff;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: bold;
    border-bottom: 3px solid #111;
  }
  
  .product-media-item img {
    width: 100%;
    height: auto;
    max-width: 100%;
    object-fit: cover;
    display: block;
    filter: drop-shadow(4px 4px 0px rgba(0,0,0,1)); /* Hard shadow on object if PNG */
  }
  
  .aspect--square img { aspect-ratio: 1 / 1; height: 100%; }
  .aspect--portrait img { aspect-ratio: 4 / 5; height: 100%; }
  .aspect--landscape img { aspect-ratio: 16 / 9; height: 100%; }
  .aspect--auto img { height: auto; }

  /* Stacked Gallery */
  .gallery-layout--stacked {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  /* Carousel Gallery */
  .gallery-layout--carousel {
    position: relative;
    overflow: hidden;
  }
  .carousel__track {
    display: flex;
    transition: transform 0s; /* Brutalist Snap */
  }
  .carousel__track.is-animating {
    transition: transform 0.2s cubic-bezier(0,0,0,1);
  }
  .carousel__slide {
    min-width: 100%;
    width: 100%;
    flex-shrink: 0;
    padding-right: 16px;
  }
  .carousel__nav {
    display: flex;
    gap: 12px;
    margin-top: 24px;
    flex-wrap: wrap;
  }
  .carousel__thumb {
    width: 64px;
    height: 64px;
    border: 3px solid #111;
    background: #fff;
    cursor: pointer;
    overflow: hidden;
    padding: 0;
    box-shadow: 2px 2px 0px #111;
  }
  .carousel__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .carousel__thumb.is-active, .carousel__thumb:active {
    box-shadow: 0px 0px 0px #111;
    transform: translate(2px, 2px);
    border-color: var(--color-cyan-accent, #00ffff);
  }

  /* Info Column Brutalist */
  .product-info-col {
    display: flex;
    flex-direction: column;
    gap: 24px;
    border: 3px solid #111;
    padding: 32px;
    background: #fff;
    box-shadow: 6px 6px 0px #111;
  }
  
  .product-block {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  
  .product__vendor {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 700;
    color: #111;
    border: 2px solid #111;
    padding: 4px 8px;
    display: inline-block;
    align-self: flex-start;
  }
  
  .product__title {
    font-family: 'Space Grotesk', sans-serif;
    font-size: clamp(32px, 4vw, 56px);
    line-height: 1;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0;
    color: #111;
  }
  
  .product__price {
    font-family: 'JetBrains Mono', monospace;
    font-size: 32px;
    font-weight: 700;
    color: #111;
    background: var(--color-cyan-accent, #0ff);
    padding: 8px 16px;
    border: 3px solid #111;
    display: inline-block;
    align-self: flex-start;
  }
  
  .product__badges {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .product__badge {
    background: #111;
    color: #fff;
    padding: 4px 12px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
  }
  
  .product__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    line-height: 1.6;
    font-weight: 500;
    color: #111;
    border-left: 4px solid #111;
    padding-left: 16px;
    background: #f4f4f4;
    padding: 16px;
  }

  /* Variant Pills Brutalist */
  .variant-fieldset {
    border: none;
    padding: 0;
    margin: 0 0 24px 0;
  }
  .variant-fieldset legend {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
    color: #111;
  }
  .variant-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }
  .variant-pill input[type="radio"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }
  .variant-pill label {
    display: inline-block;
    padding: 12px 24px;
    border: 3px solid #111;
    background: #fff;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    box-shadow: 4px 4px 0px #111;
    transition: all 0.1s;
  }
  .variant-pill input[type="radio"]:checked + label {
    background: #111;
    color: #fff;
    box-shadow: 0px 0px 0px #111;
    transform: translate(4px, 4px);
  }
  .variant-pill input[type="radio"]:focus-visible + label {
    outline: 2px dashed #111;
    outline-offset: 4px;
  }

  .add-to-cart-wrapper {
    margin-top: 16px;
  }
  .btn-cart {
    width: 100%;
    padding: 20px 24px;
    background: var(--color-magenta-accent, #f0f);
    color: #111;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 24px;
    font-weight: 700;
    text-transform: uppercase;
    border: 3px solid #111;
    box-shadow: 6px 6px 0px #111;
    cursor: pointer;
    transition: all 0.1s;
  }
  .btn-cart:active {
    box-shadow: 0px 0px 0px #111;
    transform: translate(6px, 6px);
  }
  .btn-cart:disabled {
    background: #ccc;
    color: #666;
    box-shadow: 0px 0px 0px #111;
    transform: translate(6px, 6px);
    cursor: not-allowed;
  }

  /* Specifications Brutalist */
  .product__specs {
    border-top: 3px solid #111;
    padding-top: 24px;
    margin-top: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .spec-row {
    display: flex;
    justify-content: space-between;
    padding: 12px;
    background: #111;
    color: #fff;
  }
  .spec-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    text-transform: uppercase;
    font-weight: 700;
  }
  .spec-value {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    color: var(--color-yellow-accent, #ff0);
  }
{%- endstyle -%}

<div class="product-page-wrapper">
  <div class="product-page__inner product-page__inner--{{ container_width }}">
    <div class="product-page__grid product-page__grid--{{ layout_split }}">
      
      <!-- GALLERY COLUMN -->
      <div class="product-gallery-col">
        <div class="gallery-layout--{{ gallery_layout }}" id="product-gallery">
          
          {% if gallery_layout == 'carousel' %}
            <div class="carousel__viewport">
              <div class="carousel__track" id="carousel-track">
                {% for media in product.media %}
                  <div class="carousel__slide">
                    <div class="product-media-item aspect--{{ gallery_aspect_ratio }}">
                      {{ media | image_url: width: 1400 | image_tag: loading: 'eager', widths: '375, 550, 750, 1100, 1400, 1800', sizes: '(max-width: 768px) 100vw, (max-width: 1200px) 60vw, 50vw' }}
                    </div>
                  </div>
                {% endfor %}
              </div>
            </div>
            
            {% if product.media.size > 1 %}
              <div class="carousel__nav" id="carousel-nav">
                {% for media in product.media %}
                  <button class="carousel__thumb {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}">
                    {{ media | image_url: width: 150 | image_tag: loading: 'lazy', widths: '100, 150, 200, 300', sizes: '100px' }}
                  </button>
                {% endfor %}
              </div>
            {% endif %}
            
          {% else %}
            <!-- Stacked Layout -->
            {% for media in product.media %}
              <div class="product-media-item aspect--{{ gallery_aspect_ratio }}">
                {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', widths: '375, 550, 750, 1100, 1400, 1800', sizes: '(max-width: 768px) 100vw, (max-width: 1200px) 60vw, 50vw' }}
              </div>
            {% endfor %}
          {% endif %}
          
        </div>
      </div>

      <!-- INFO COLUMN -->
      <div class="product-info-col">
        <div class="w-full h-8 bg-text-dark flex items-center px-3 justify-between -mt-8 -mx-8 mb-4 shrink-0" style="width: calc(100% + 64px);">
          <span class="font-mono text-xs font-bold text-surface">PRODUCT_SYS.EXE</span>
          <div class="flex gap-2">
            <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
            <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
            <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
          </div>
        </div>

        {% for block in section.blocks %}
          <div class="product-block product-block--{{ block.type }}" {{ block.shopify_attributes }}>
            
            {% case block.type %}
              
              {% when 'vendor' %}
                <div class="product__vendor">MFR: {{ product.vendor | escape }}</div>
              
              {% when 'title' %}
                <h1 class="product__title">{{ product.title | escape }}</h1>
                
              {% when 'price' %}
                <div class="product__price" id="price-{{ section.id }}">
                  {{ product.price | money }}
                </div>
                
              {% when 'badges' %}
                {% if product.tags.size > 0 %}
                  <div class="product__badges">
                    {% for tag in product.tags limit: 4 %}
                      <span class="product__badge">[{{ tag | escape }}]</span>
                    {% endfor %}
                  </div>
                {% endif %}
                
              {% when 'description' %}
                <div class="product__desc">
                  <span class="font-bold mb-2 block">>>> SYSTEM_LOG:</span>
                  {{ product.description }}
                </div>
                
              {% when 'whatsapp_request' %}
                <div class="product__whatsapp">
                  {%- assign wa_num = block.settings.whatsapp_number | replace: ' ', '' | replace: '+', '' | replace: '-', '' -%}
                  {%- capture default_wa_link -%}https://wa.me/{{ wa_num }}?text=I'm%20interested%20in%20{{ product.title | url_param_escape }}%20-%20{{ shop.url }}{{ product.url }}{%- endcapture -%}
                  
                  <a href="{% if wa_num != blank %}{{ default_wa_link }}{% else %}#{% endif %}" class="btn-brutalist block w-full text-center bg-yellow-accent border-3 border-text-dark shadow-brutalist rounded-sm py-3 font-display font-bold uppercase tracking-wider text-text-dark hover:bg-surface transition-colors" target="_blank" rel="noopener noreferrer">
                    {{ block.settings.button_text | default: 'Request This' }}
                  </a>
                </div>
                
              {% when 'form' %}
                <div class="product__form-block">
                  {%- form 'product', product, id: 'product-form-main', class: 'form', novalidate: 'novalidate', data-type: 'add-to-cart-form' -%}
                    
                    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                    
                    {%- unless product.has_only_default_variant -%}
                      {%- for option in product.options_with_values -%}
                        <fieldset class="variant-fieldset">
                          <legend>SELECT {{ option.name }}</legend>
                          <div class="variant-pills">
                            {%- for value in option.values -%}
                              <div class="variant-pill">
                                <input 
                                  type="radio" 
                                  id="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}"
                                  name="options[{{ option.name | escape }}]"
                                  value="{{ value | escape }}"
                                  form="product-form-main"
                                  {% if option.selected_value == value %}checked{% endif %}
                                >
                                <label for="{{ section.id }}-{{ option.position }}-{{ forloop.index0 }}">
                                  {{ value | escape }}
                                </label>
                              </div>
                            {%- endfor -%}
                          </div>
                        </fieldset>
                      {%- endfor -%}
                    {%- endunless -%}

                    <div class="add-to-cart-wrapper">
                      <button
                        type="submit"
                        name="add"
                        class="btn-cart"
                        {% if product.selected_or_first_available_variant.available == false %}disabled{% endif %}
                      >
                        {%- if product.selected_or_first_available_variant.available -%}
                          EXECUTE [ADD TO CART]
                        {%- else -%}
                          ERR: OUT_OF_STOCK
                        {%- endif -%}
                      </button>
                    </div>
                  {%- endform -%}
                </div>
                
              {% when 'specs' %}
                {% if product.metafields.custom.spec_1_label.value != blank %}
                  <div class="product__specs">
                    {% if product.metafields.custom.spec_1_label.value != blank %}
                      <div class="spec-row">
                        <span class="spec-label">{{ product.metafields.custom.spec_1_label.value | escape }}</span>
                        <span class="spec-value">{{ product.metafields.custom.spec_1_value.value | escape }}</span>
                      </div>
                    {% endif %}
                    {% if product.metafields.custom.spec_2_label.value != blank %}
                      <div class="spec-row">
                        <span class="spec-label">{{ product.metafields.custom.spec_2_label.value | escape }}</span>
                        <span class="spec-value">{{ product.metafields.custom.spec_2_value.value | escape }}</span>
                      </div>
                    {% endif %}
                    {% if product.metafields.custom.spec_3_label.value != blank %}
                      <div class="spec-row">
                        <span class="spec-label">{{ product.metafields.custom.spec_3_label.value | escape }}</span>
                        <span class="spec-value">{{ product.metafields.custom.spec_3_value.value | escape }}</span>
                      </div>
                    {% endif %}
                  </div>
                {% endif %}

            {% endcase %}
            
          </div>
        {% endfor %}
      </div>
      
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    // Carousel Logic
    const track = document.getElementById('carousel-track');
    const thumbs = document.querySelectorAll('.carousel__thumb');
    
    if (track && thumbs.length > 0) {
      thumbs.forEach((thumb) => {
        thumb.addEventListener('click', (e) => {
          const index = e.currentTarget.dataset.index;
          const slideWidth = track.parentElement.clientWidth;
          
          track.classList.add('is-animating');
          track.style.transform = `translateX(-${index * slideWidth}px)`;
          setTimeout(() => track.classList.remove('is-animating'), 200);
          
          thumbs.forEach(t => t.classList.remove('is-active'));
          e.currentTarget.classList.add('is-active');
        });
      });
      
      // Handle resize to update transform
      window.addEventListener('resize', () => {
        const activeThumb = document.querySelector('.carousel__thumb.is-active');
        if (activeThumb) {
          const index = activeThumb.dataset.index;
          const slideWidth = track.parentElement.clientWidth;
          track.style.transform = `translateX(-${index * slideWidth}px)`;
        }
      });
    }

    // Variant Selection Logic
    const variantRadios = document.querySelectorAll('.variant-pill input[type="radio"]');
    const hiddenIdInput = document.querySelector('input[name="id"]');
    const submitBtn = document.querySelector('.btn-cart');
    const priceDisplay = document.getElementById('price-{{ section.id }}');
    
    // Parse variants json generated by shopify
    const productVariants = {{ product.variants | json }};
    
    variantRadios.forEach(radio => {
      radio.addEventListener('change', () => {
        // Collect currently selected options
        const fieldsets = document.querySelectorAll('.variant-fieldset');
        const selectedOptions = Array.from(fieldsets).map(fieldset => {
          return fieldset.querySelector('input[type="radio"]:checked').value;
        });
        
        // Find matching variant
        const matchedVariant = productVariants.find(variant => {
          return selectedOptions.every((opt, index) => variant.options[index] === opt);
        });
        
        if (matchedVariant) {
          hiddenIdInput.value = matchedVariant.id;
          
          // Update URL
          window.history.replaceState({}, '', `${window.location.pathname}?variant=${matchedVariant.id}`);
          
          // Update price formatting (basic)
          if(priceDisplay) {
            priceDisplay.textContent = new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(matchedVariant.price / 100);
          }
          
          if (matchedVariant.available) {
            submitBtn.disabled = false;
            submitBtn.textContent = 'EXECUTE [ADD TO CART]';
          } else {
            submitBtn.disabled = true;
            submitBtn.textContent = 'ERR: OUT_OF_STOCK';
          }
        } else {
          submitBtn.disabled = true;
          submitBtn.textContent = 'ERR: UNAVAILABLE';
        }
      });
    });
  });
</script>

{% schema %}
{
  "name": "Product Details",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "container_width",
      "label": "Container Width",
      "options": [
        { "value": "standard", "label": "Standard (1440px)" },
        { "value": "narrow", "label": "Narrow (1000px)" },
        { "value": "full", "label": "Full Width" }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "layout_split",
      "label": "Desktop Split (Media / Info)",
      "options": [
        { "value": "5050", "label": "50% / 50%" },
        { "value": "6040", "label": "60% / 40%" },
        { "value": "6535", "label": "65% / 35%" }
      ],
      "default": "6040"
    },
    {
      "type": "header",
      "content": "Gallery"
    },
    {
      "type": "select",
      "id": "gallery_layout",
      "label": "Gallery Layout",
      "options": [
        { "value": "carousel", "label": "Carousel with Thumbnails" },
        { "value": "stacked", "label": "Stacked Scroll" }
      ],
      "default": "carousel"
    },
    {
      "type": "select",
      "id": "gallery_aspect_ratio",
      "label": "Image Crop",
      "options": [
        { "value": "auto", "label": "Original Size" },
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "landscape", "label": "Landscape (16:9)" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#111111"
    }
  ],
  "blocks": [
    {
      "type": "vendor",
      "name": "Vendor",
      "limit": 1,
      "settings": []
    },
    {
      "type": "title",
      "name": "Title",
      "limit": 1,
      "settings": []
    },
    {
      "type": "price",
      "name": "Price",
      "limit": 1,
      "settings": []
    },
    {
      "type": "badges",
      "name": "Product Tags/Badges",
      "limit": 1,
      "settings": []
    },
    {
      "type": "form",
      "name": "Variant Picker & Cart",
      "limit": 1,
      "settings": []
    },
    {
      "type": "description",
      "name": "Description",
      "limit": 1,
      "settings": []
    },
    {
      "type": "whatsapp_request",
      "name": "WhatsApp Request Button",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "button_text",
          "label": "Button Text",
          "default": "REQUEST THIS"
        },
        {
          "type": "text",
          "id": "whatsapp_number",
          "label": "WhatsApp Business Number",
          "info": "Include country code without '+' (e.g., 1234567890)"
        }
      ]
    },
    {
      "type": "specs",
      "name": "Specifications",
      "limit": 1,
      "settings": []
    }
  ],
  "presets": [
    {
      "name": "Product Details",
      "blocks": [
        { "type": "vendor" },
        { "type": "title" },
        { "type": "price" },
        { "type": "badges" },
        { "type": "form" },
        { "type": "description" },
        { "type": "specs" }
      ]
    }
  ]
}
{% endschema %}
