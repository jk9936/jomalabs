<section class="max-w-7xl mx-auto px-4 py-16 md:py-24">
  <div class="flex flex-col items-center gap-12">
    {% if section.settings.heading != blank %}
      <div class="w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between max-w-[800px]">
        <span class="font-mono text-xs font-bold text-surface">SYS.CAROUSEL_VIEWER</span>
        <div class="flex gap-2">
          <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
          <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
          <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
        </div>
      </div>
      <h2 class="font-display font-bold text-4xl md:text-6xl uppercase leading-none text-text-dark text-center -mt-8">
        {{ section.settings.heading | escape }}
      </h2>
    {% endif %}

    <print-carousel class="w-full max-w-[800px] flex flex-col items-center gap-8" data-blocks-count="{{ section.blocks.size }}">
      
      <!-- Main Highlight Frame -->
      <div class="w-full flex flex-col items-center gap-6">
        <div class="print-carousel__frame w-full aspect-square max-w-[500px] border-3 border-text-dark bg-background-light p-4 md:p-6 shadow-brutalist relative overflow-hidden">
          <div class="w-full h-full relative border-3 border-text-dark bg-surface overflow-hidden">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product != blank -%}
                <img 
                  src="{{ product.featured_image | image_url: width: 800 }}" 
                  alt="{{ product.title | escape }}"
                  class="absolute inset-0 w-full h-full object-cover opacity-0 invisible transition-all duration-300 print-carousel__main-image {% if forloop.first %}is-active opacity-100 visible filter hover:brightness-110{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  loading="lazy"
                >
              {%- endif -%}
            {%- endfor -%}
            {%- if section.blocks.size == 0 -%}
              <div class="w-full h-full flex items-center justify-center bg-surface">
                {{ 'product-1' | placeholder_svg_tag: 'w-1/2 h-1/2 opacity-20' }}
              </div>
            {%- endif -%}
          </div>
          {% if section.blocks.size > 1 %}
            <button class="print-carousel__arrow print-carousel__arrow--prev absolute top-1/2 -translate-y-1/2 left-0 -ml-4 md:ml-4 w-12 h-12 bg-yellow-accent border-3 border-text-dark flex items-center justify-center text-text-dark hover:bg-surface shadow-[4px_4px_0px_#111] hover:shadow-[0px_0px_0px_#111] hover:translate-x-1 hover:translate-y-1 transition-all z-10" aria-label="Previous">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="print-carousel__arrow print-carousel__arrow--next absolute top-1/2 -translate-y-1/2 right-0 -mr-4 md:mr-4 w-12 h-12 bg-yellow-accent border-3 border-text-dark flex items-center justify-center text-text-dark hover:bg-surface shadow-[4px_4px_0px_#111] hover:shadow-[0px_0px_0px_#111] hover:translate-x-1 hover:translate-y-1 transition-all z-10" aria-label="Next">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          {% endif %}
        </div>
        
        <!-- Active Print Name -->
        <div class="print-carousel__info text-center bg-text-dark text-white border-3 border-text-dark px-6 py-3 w-full max-w-[500px] shadow-brutalist">
          {%- for block in section.blocks -%}
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              <h3 
                class="print-carousel__title font-mono text-sm md:text-base font-bold uppercase tracking-widest hidden {% if forloop.first %}!block{% endif %}"
                data-index="{{ forloop.index0 }}"
              >
                >>> {{ product.title | escape }}
              </h3>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    </print-carousel>
  </div>
</section>

<script>
  if (!customElements.get('print-carousel')) {
    class PrintCarousel extends HTMLElement {
      constructor() {
        super();
        this.images = Array.from(this.querySelectorAll('.print-carousel__main-image'));
        this.titles = Array.from(this.querySelectorAll('.print-carousel__title'));
        this.prevBtn = this.querySelector('.print-carousel__arrow--prev');
        this.nextBtn = this.querySelector('.print-carousel__arrow--next');
        
        this.currentIndex = 0;
        this.total = this.images.length;
        
        if (this.total > 1) {
          if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.prev());
          if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.next());
          
          this.initSwipe();
        }
      }
      
      initSwipe() {
        let touchstartX = 0;
        let touchendX = 0;
        const frame = this.querySelector('.print-carousel__frame');
        if (!frame) return;
        
        frame.addEventListener('touchstart', e => {
          touchstartX = e.changedTouches[0].screenX;
        }, { passive: true });
        
        frame.addEventListener('touchend', e => {
          touchendX = e.changedTouches[0].screenX;
          this.handleSwipe(touchstartX, touchendX);
        }, { passive: true });
      }
      
      handleSwipe(startX, endX) {
        const threshold = 40;
        if (startX - endX > threshold) {
          this.next(); // Swiped left
        } else if (endX - startX > threshold) {
          this.prev(); // Swiped right
        }
      }
      
      prev() {
        this.currentIndex = (this.currentIndex - 1 + this.total) % this.total;
        this.updateView();
      }
      
      next() {
        this.currentIndex = (this.currentIndex + 1) % this.total;
        this.updateView();
      }
      
      updateView() {
        this.images.forEach(el => {
          el.classList.remove('is-active', 'opacity-100', 'visible', 'filter', 'hover:brightness-110');
          el.classList.add('opacity-0', 'invisible');
        });
        this.titles.forEach(el => el.classList.remove('!block'));
        
        if (this.images[this.currentIndex]) {
          this.images[this.currentIndex].classList.remove('opacity-0', 'invisible');
          this.images[this.currentIndex].classList.add('is-active', 'opacity-100', 'visible', 'filter', 'hover:brightness-110');
        }
        if (this.titles[this.currentIndex]) {
          this.titles[this.currentIndex].classList.add('!block');
        }
      }
    }
    customElements.define('print-carousel', PrintCarousel);
  }
</script>

{% schema %}
{
  "name": "Print Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hot Off the Nozzle 🔥"
    }
  ],
  "blocks": [
    {
      "type": "print",
      "name": "Print",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product to feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Print Carousel",
      "blocks": [
        { "type": "print" },
        { "type": "print" },
        { "type": "print" }
      ]
    }
  ]
}
{% endschema %}
