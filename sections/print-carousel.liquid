<section class="section-print-carousel page-section">
  <div class="print-carousel__inner">
    {% if section.settings.heading != blank %}
      <h2 class="print-carousel__heading font-serif text-center" style="text-align: center;">{{ section.settings.heading | escape }}</h2>
    {% endif %}

    <print-carousel class="print-carousel" data-blocks-count="{{ section.blocks.size }}">
      
      <!-- Main Highlight Frame -->
      <div class="print-carousel__frame-wrapper">
        <div class="print-carousel__frame">
          <div class="print-carousel__main-image-container">
            {%- for block in section.blocks -%}
              {%- assign product = block.settings.product -%}
              {%- if product != blank -%}
                <img 
                  src="{{ product.featured_image | image_url: width: 800 }}" 
                  alt="{{ product.title | escape }}"
                  class="print-carousel__main-image {% if forloop.first %}is-active{% endif %}"
                  data-index="{{ forloop.index0 }}"
                  loading="lazy"
                >
              {%- endif -%}
            {%- endfor -%}
            {%- if section.blocks.size == 0 -%}
              <div class="print-carousel__placeholder">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {%- endif -%}
          </div>
          {% if section.blocks.size > 1 %}
            <button class="print-carousel__arrow print-carousel__arrow--prev" aria-label="Previous">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="print-carousel__arrow print-carousel__arrow--next" aria-label="Next">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          {% endif %}
        </div>
        
        <!-- Active Print Name -->
        <div class="print-carousel__info text-center" style="text-align: center;">
          {%- for block in section.blocks -%}
            {%- assign product = block.settings.product -%}
            {%- if product != blank -%}
              <h3 
                class="print-carousel__title font-serif {% if forloop.first %}is-active{% endif %}"
                data-index="{{ forloop.index0 }}"
              >
                {{ product.title | escape }}
              </h3>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

    </print-carousel>
  </div>
</section>

{% style %}
  .section-print-carousel {
    background-color: var(--color-surface-container-low);
    padding: 96px var(--space-margin-mobile);
  }
  @media (min-width: 768px) {
    .section-print-carousel {
      padding: 120px var(--space-margin-desktop);
    }
  }

  .print-carousel__heading {
    margin: 0 0 48px 0;
    font-size: var(--text-display-lg);
    color: var(--color-primary);
  }
  
  .print-carousel {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
    max-width: 800px;
    margin: 0 auto;
  }

  .print-carousel__frame-wrapper {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 32px;
  }

  .print-carousel__frame {
    width: 100%;
    aspect-ratio: 1 / 1;
    max-width: 500px;
    background-color: var(--color-surface);
    padding: 20px;
    border-radius: 8px;
    box-shadow: var(--shadow-modal);
    border: 1px solid rgba(24, 36, 27, 0.05);
    position: relative;
    overflow: hidden;
  }

  .print-carousel__main-image-container {
    width: 100%;
    height: 100%;
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    background-color: var(--color-surface-dim);
  }

  .print-carousel__main-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.5s ease, visibility 0.5s ease;
  }
  .print-carousel__main-image.is-active {
    opacity: 1;
    visibility: visible;
  }

  .print-carousel__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .print-carousel__placeholder svg {
    width: 50%;
    height: 50%;
    fill: rgba(0,0,0,0.1);
  }

  .print-carousel__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    background-color: rgba(255, 255, 255, 0.95);
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(24, 36, 27, 0.1);
    color: var(--color-primary);
    z-index: 10;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .print-carousel__arrow:hover {
    background-color: #fff;
    transform: translateY(-50%) scale(1.05);
  }
  .print-carousel__arrow--prev {
    left: 32px;
  }
  .print-carousel__arrow--next {
    right: 32px;
  }

  .print-carousel__title {
    font-size: 28px;
    color: var(--color-primary);
    margin: 0;
    display: none;
    font-style: italic;
  }
  .print-carousel__title.is-active {
    display: block;
    animation: fadeIn 0.5s ease;
  }

  @media (max-width: 767px) {
    .print-carousel__heading {
      font-size: var(--text-headline-lg);
    }
    .print-carousel__frame {
      aspect-ratio: 4 / 5;
      padding: 12px;
    }
    .print-carousel__title {
      font-size: 24px;
    }
    .print-carousel__arrow {
      width: 36px;
      height: 36px;
      box-shadow: 0 2px 8px rgba(24, 36, 27, 0.15);
    }
    .print-carousel__arrow--prev {
      left: 20px;
    }
    .print-carousel__arrow--next {
      right: 20px;
    }
  }
{% endstyle %}

<script>
  if (!customElements.get('print-carousel')) {
    class PrintCarousel extends HTMLElement {
      constructor() {
        super();
        this.images = Array.from(this.querySelectorAll('.print-carousel__main-image'));
        this.titles = Array.from(this.querySelectorAll('.print-carousel__title'));
        this.prevBtn = this.querySelector('.print-carousel__arrow--prev');
        this.nextBtn = this.querySelector('.print-carousel__arrow--next');
        
        this.currentIndex = 0;
        this.total = this.images.length;
        
        if (this.total > 1) {
          if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.prev());
          if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.next());
          
          this.initSwipe();
        }
      }
      
      initSwipe() {
        let touchstartX = 0;
        let touchendX = 0;
        const frame = this.querySelector('.print-carousel__frame');
        if (!frame) return;
        
        frame.addEventListener('touchstart', e => {
          touchstartX = e.changedTouches[0].screenX;
        }, { passive: true });
        
        frame.addEventListener('touchend', e => {
          touchendX = e.changedTouches[0].screenX;
          this.handleSwipe(touchstartX, touchendX);
        }, { passive: true });
      }
      
      handleSwipe(startX, endX) {
        const threshold = 40;
        if (startX - endX > threshold) {
          this.next(); // Swiped left
        } else if (endX - startX > threshold) {
          this.prev(); // Swiped right
        }
      }
      
      prev() {
        this.currentIndex = (this.currentIndex - 1 + this.total) % this.total;
        this.updateView();
      }
      
      next() {
        this.currentIndex = (this.currentIndex + 1) % this.total;
        this.updateView();
      }
      
      updateView() {
        this.images.forEach(el => el.classList.remove('is-active'));
        this.titles.forEach(el => el.classList.remove('is-active'));
        
        if (this.images[this.currentIndex]) this.images[this.currentIndex].classList.add('is-active');
        if (this.titles[this.currentIndex]) this.titles[this.currentIndex].classList.add('is-active');
      }
    }
    customElements.define('print-carousel', PrintCarousel);
  }
</script>

{% schema %}
{
  "name": "Print Carousel",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Hot Off the Nozzle 🔥"
    }
  ],
  "blocks": [
    {
      "type": "print",
      "name": "Print",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product to feature"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Print Carousel",
      "blocks": [
        { "type": "print" },
        { "type": "print" },
        { "type": "print" }
      ]
    }
  ]
}
{% endschema %}
