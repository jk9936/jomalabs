<div id="header-hover-zone" class="fixed top-0 left-0 w-full h-8 z-[60] hidden md:block"></div>
<header id="site-header" class="fixed top-0 left-0 right-0 z-50 flex flex-col brutalist-border border-b-3 shadow-brutalist transition-transform duration-300 ease-in-out" style="background-color: {{ section.settings.header_bg }};">
  <!-- OS Top Bar -->
  {%- if section.settings.show_os_bar -%}
  <div class="w-full h-8 flex items-center px-3 justify-between shrink-0 border-b-3 border-text-dark" style="background-color: {{ section.settings.os_bg }}; color: {{ section.settings.os_text_color }};">
    <span class="font-mono text-xs font-bold tracking-widest">
      {%- if section.settings.os_text != blank -%}
        {{ section.settings.os_text | escape }}
      {%- else -%}
        JOMA_OS.EXE
      {%- endif -%}
    </span>
    <div class="flex gap-2">
      <div class="w-3 h-3 border-2 border-text-dark" style="background-color: {{ section.settings.os_dot_1 }};"></div>
      <div class="w-3 h-3 border-2 border-text-dark" style="background-color: {{ section.settings.os_dot_2 }};"></div>
      <div class="w-3 h-3 border-2 border-text-dark" style="background-color: {{ section.settings.os_dot_3 }};"></div>
    </div>
  </div>
  {%- endif -%}

  <!-- Main Navigation Area -->
  <div class="h-16 flex items-center justify-between px-4">
    <div class="flex items-center gap-2">
      <a href="{{ routes.root_url }}" class="font-display font-bold text-xl uppercase tracking-tighter text-text-dark hover:opacity-80 transition-opacity">
        {%- if section.settings.logo_text != blank -%}
          {{ section.settings.logo_text | escape }}
        {%- else -%}
          JOMA_LABS
        {%- endif -%}
      </a>
    </div>

    <div class="flex items-center justify-end gap-6">
      <!-- Desktop Nav -->
      <nav class="hidden md:flex items-center gap-6" aria-label="Primary navigation">
        {%- for block in section.blocks -%}
          {%- if block.type == 'nav_link' -%}
            <a
              href="{{ block.settings.url | escape }}"
              class="font-mono text-sm font-bold uppercase tracking-wider text-text-dark hover:text-magenta-accent hover:underline underline-offset-4 decoration-2 transition-all {% if block.settings.accent %}text-cyan-accent{% endif %}"
            >
              {{ block.settings.label | escape }}
            </a>
          {%- endif -%}
        {%- endfor -%}
        {%- if shop.customer_accounts_enabled -%}
          <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="font-mono text-sm font-bold uppercase tracking-wider text-text-dark hover:text-magenta-accent transition-colors">
            <span class="material-symbols-outlined align-middle text-lg">person</span>
          </a>
        {%- endif -%}
      </nav>

      <!-- Cart Button -->
      <button class="relative flex items-center justify-center p-2 cursor-pointer btn-brutalist rounded-sm bg-surface brutalist-border shadow-brutalist" data-cart-open aria-label="Open cart">
        <span class="material-symbols-outlined text-text-dark font-bold" style="font-variation-settings: 'FILL' 1;">shopping_cart</span>
        <span class="cart-count absolute -top-2 -right-2 w-5 h-5 bg-magenta-accent brutalist-border rounded-full flex items-center justify-center text-[10px] font-bold text-text-dark {% if cart.item_count == 0 %}hidden{% endif %}">
          {{ cart.item_count }}
        </span>
      </button>
      
      <!-- Mobile Hamburger -->
      <button class="md:hidden flex items-center justify-center p-2 cursor-pointer btn-brutalist rounded-sm bg-surface brutalist-border shadow-brutalist site-header__hamburger">
        <span class="material-symbols-outlined text-text-dark font-bold">menu</span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile Nav Drawer -->
<nav class="site-header__mobile-nav fixed top-24 left-0 w-full brutalist-border border-b-3 z-40 hidden flex-col divide-y-3 divide-text-dark shadow-brutalist" style="background-color: {{ section.settings.header_bg }};">
  {%- for block in section.blocks -%}
    {%- if block.type == 'nav_link' -%}
      <a href="{{ block.settings.url | escape }}" class="font-mono text-sm font-bold uppercase tracking-wider text-text-dark p-4 hover:bg-background-light">
        {{ block.settings.label | escape }}
      </a>
    {%- endif -%}
  {%- endfor -%}
  {%- if shop.customer_accounts_enabled -%}
    <a href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}" class="font-mono text-sm font-bold uppercase tracking-wider text-text-dark p-4 hover:bg-background-light">
      {%- if customer -%}My Account{%- else -%}Log In{%- endif -%}
    </a>
  {%- endif -%}
</nav>

{% schema %}
{
  "name": "Header",
  "tag": "div",
  "class": "site-header-section relative z-50",
  "settings": [
    {
      "type": "header",
      "content": "OS Top Bar"
    },
    {
      "type": "checkbox",
      "id": "show_os_bar",
      "label": "Show OS Top Bar",
      "default": true
    },
    {
      "type": "text",
      "id": "os_text",
      "label": "OS Bar Text",
      "default": "JOMA_OS.EXE"
    },
    {
      "type": "color",
      "id": "os_bg",
      "label": "OS Bar Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "os_text_color",
      "label": "OS Bar Text Color",
      "default": "#EAEAEA"
    },
    {
      "type": "color",
      "id": "os_dot_1",
      "label": "OS Dot 1 Color",
      "default": "#00FFFF"
    },
    {
      "type": "color",
      "id": "os_dot_2",
      "label": "OS Dot 2 Color",
      "default": "#FF00FF"
    },
    {
      "type": "color",
      "id": "os_dot_3",
      "label": "OS Dot 3 Color",
      "default": "#f2cc0d"
    },
    {
      "type": "header",
      "content": "Main Header"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text",
      "default": "JOMA_LABS"
    },
    {
      "type": "color",
      "id": "header_bg",
      "label": "Header Background Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Navigation link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Tools"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        },
        {
          "type": "checkbox",
          "id": "accent",
          "label": "Accent style",
          "default": false
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Header",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Hardware", "url": "#hardware", "accent": false } },
        { "type": "nav_link", "settings": { "label": "Apparel", "url": "#apparel", "accent": false } },
        { "type": "nav_link", "settings": { "label": "Workspace", "url": "#workspace", "accent": true } }
      ]
    }
  ]
}
{% endschema %}
