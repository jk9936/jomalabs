{%- style -%}
  .phc-wrapper {
    width: 100%;
    padding: 16px;
    box-sizing: border-box;
  }
  
  {% if section.settings.container_width == 'full' %}
    .phc-wrapper { padding: 0; }
    .phc-container { border-radius: 0 !important; }
  {% elsif section.settings.container_width == 'narrow' %}
    .phc-wrapper { max-width: 1200px; margin: 0 auto; }
  {% else %}
    .phc-wrapper { max-width: 1600px; margin: 0 auto; }
  {% endif %}

  .phc-container {
    display: block;
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--color-background, #fff);
    border: 3px solid #111;
    border-radius: 2px;
    box-shadow: 6px 6px 0px #111;
    {% if section.settings.height == 'small' %} min-height: 50vh; {% endif %}
    {% if section.settings.height == 'medium' %} min-height: 70vh; {% endif %}
    {% if section.settings.height == 'large' %} min-height: 90vh; {% endif %}
    {% if section.settings.height == 'full' %} min-height: 100vh; {% endif %}
  }

  .phc-track {
    display: flex;
    width: 100%;
    height: 100%;
    position: absolute;
    top: 0;
    left: 0;
    transition: transform 0s; /* Brutalist snap or very fast transition */
  }

  .phc-track.is-animating {
    transition: transform 0.4s cubic-bezier(0,0,0,1);
  }

  .phc-slide {
    flex: 0 0 100%;
    width: 100%;
    height: 100%;
    position: relative;
    display: flex;
    align-items: center;
    overflow: hidden;
    border-right: 3px solid #111;
  }
  .phc-slide:last-child {
    border-right: none;
  }

  /* Split Layout */
  .phc-slide__inner {
    display: flex;
    width: 100%;
    height: 100%;
    flex-direction: column-reverse; /* Mobile default */
    position: relative;
    z-index: 10;
  }
  
  @media (min-width: 992px) {
    .phc-slide__inner {
      flex-direction: row;
    }
  }

  .phc-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 24px;
    padding-bottom: 120px; /* Prevent overlap with nav controls on mobile */
    z-index: 2;
    text-align: left;
    border-top: 3px solid #111;
    background-color: var(--phc-bg-color);
  }
  @media (min-width: 992px) {
    .phc-content {
      padding: 40px;
      border-top: none;
      border-right: 3px solid #111;
      max-width: 450px;
    }
  }

  .phc-content__subheading {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: inline-block;
    padding: 4px 8px;
    border: 2px solid #111;
    background: #fff;
    color: #111;
    align-self: flex-start;
  }
  
  .phc-content__heading {
    font-family: 'Space Grotesk', sans-serif;
    font-size: var(--phc-heading-size-mobile, 32px);
    line-height: 1;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0 0 16px 0;
    color: var(--phc-text-color);
  }
  
  .phc-content__desc {
    font-family: 'JetBrains Mono', monospace;
    font-size: var(--phc-desc-size-mobile, 14px);
    font-weight: 700;
    line-height: 1.4;
    margin-bottom: 32px;
    color: var(--phc-text-color);
  }
  
  @media (min-width: 992px) {
    .phc-content__heading {
      font-size: var(--phc-heading-size-desktop, 64px);
    }
    .phc-content__desc {
      font-size: var(--phc-desc-size-desktop, 14px);
    }
  }

  .phc-content__btn {
    display: inline-block;
    padding: 12px 24px;
    border: 3px solid #111;
    background: var(--phc-accent-color);
    color: #111;
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700;
    font-size: 16px;
    text-transform: uppercase;
    text-decoration: none;
    box-shadow: 4px 4px 0px #111;
    transition: all 0.1s;
    align-self: flex-start;
  }
  .phc-content__btn:active {
    box-shadow: 0px 0px 0px #111;
    transform: translate(4px, 4px);
  }

  /* Stage (Right on Desktop, Top on Mobile) */
  .phc-stage {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
    z-index: 1;
    background-color: var(--phc-accent-color);
    background-image: radial-gradient(#111 2px, transparent 2px);
    background-size: 30px 30px;
    overflow: hidden;
  }
  
  .phc-stage__product {
    --phc-pos-x: var(--phc-pos-x-mobile, 0px);
    --phc-pos-y: var(--phc-pos-y-mobile, 0px);
    position: relative;
    z-index: 3;
    max-width: 90%;
    max-height: 90%;
    width: 100%;
    transform: scale(var(--phc-image-scale, 1)) translate(var(--phc-pos-x, 0px), var(--phc-pos-y, 0px));
    display: flex;
    justify-content: center;
    align-items: center;
  }
  @media (min-width: 992px) {
    .phc-stage__product {
      --phc-pos-x: var(--phc-pos-x-desktop, 0px);
      --phc-pos-y: var(--phc-pos-y-desktop, 0px);
    }
  }

  .phc-stage__product-img {
    width: 100%;
    height: 100%;
    max-height: 40vh;
    object-fit: contain;
    filter: drop-shadow(4px 4px 0px rgba(0,0,0,1));
  }
  @media (min-width: 992px) {
    .phc-stage__product-img {
      max-height: 70vh;
      filter: drop-shadow(8px 8px 0px rgba(0,0,0,1));
    }
  }

  /* Navigation */
  .phc-nav-wrap {
    position: absolute;
    bottom: 24px;
    right: 24px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    align-items: flex-end;
    z-index: 20;
  }

  .phc-arrows {
    display: flex;
    gap: 8px;
  }

  .phc-arrow {
    width: 48px;
    height: 48px;
    border: 3px solid #111;
    background: #fff;
    color: #111;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    box-shadow: 4px 4px 0px #111;
  }
  .phc-arrow:active {
    box-shadow: 0px 0px 0px #111;
    transform: translate(4px, 4px);
  }
  
  .phc-nav {
    display: flex;
    gap: 8px;
  }
  
  .phc-dot {
    width: 32px;
    height: 32px;
    border: 2px solid #111;
    background: #fff;
    cursor: pointer;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    font-size: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #111;
  }
  .phc-dot.is-active {
    background: #111;
    color: #fff;
  }
{%- endstyle -%}

<section class="phc-wrapper">
  <premium-hero-carousel 
    class="phc-container"
    data-autoplay="{{ section.settings.autoplay }}"
    data-speed="{{ section.settings.autoplay_speed | times: 1000 }}"
    aria-roledescription="carousel"
  >
    <div class="phc-track">
      {% for block in section.blocks %}
        {%- assign bg_color = block.settings.bg_color | default: '#f4f4f4' -%}
        {%- assign accent_color = block.settings.accent_color | default: '#e1e1e1' -%}
        <div class="phc-slide {% if forloop.first %}is-active{% endif %}" 
             data-index="{{ forloop.index0 }}"
             aria-roledescription="slide"
             aria-hidden="{% if forloop.first %}false{% else %}true{% endif %}"
             {{ block.shopify_attributes }} 
           style="
             --phc-bg-color: {{ block.settings.bg_color }}; 
             --phc-accent-color: {{ block.settings.accent_color }}; 
             --phc-text-color: {{ block.settings.text_color }};
             --phc-heading-size-mobile: {{ block.settings.heading_size_mobile }}px;
             --phc-heading-size-desktop: {{ block.settings.heading_size_desktop }}px;
             --phc-desc-size-mobile: {{ block.settings.desc_size_mobile }}px;
             --phc-desc-size-desktop: {{ block.settings.desc_size_desktop }}px;
           ">
          
          <div class="phc-slide__inner">
            <!-- Content Layer -->
            <div class="phc-content">
              {% if block.settings.subheading != blank %}
                <div class="phc-content__subheading">{{ block.settings.subheading | escape }}</div>
              {% endif %}
              
              {% if block.settings.heading != blank %}
                <h2 class="phc-content__heading">{{ block.settings.heading | escape }}</h2>
              {% endif %}
              
              {% if block.settings.description != blank %}
                <div class="phc-content__desc">{{ block.settings.description }}</div>
              {% endif %}
              
              {% if block.settings.btn_text != blank and block.settings.btn_url != blank %}
                <a href="{{ block.settings.btn_url }}" class="phc-content__btn">
                  {{ block.settings.btn_text | escape }}
                </a>
              {% endif %}
            </div>
            
            <!-- Stage / Product Layer -->
            <div class="phc-stage">
              <div class="phc-stage__product" style="--phc-image-scale: {{ block.settings.image_scale | divided_by: 100.0 }}; --phc-pos-x-desktop: {{ block.settings.pos_x }}px; --phc-pos-y-desktop: {{ block.settings.pos_y }}px; --phc-pos-x-mobile: {{ block.settings.pos_x_mobile }}px; --phc-pos-y-mobile: {{ block.settings.pos_y_mobile }}px; rotate: {{ block.settings.rotation }}deg;">
                {% if block.settings.product_image %}
                  <img 
                    src="{{ block.settings.product_image | image_url: width: 1200 }}" 
                    alt="{{ block.settings.heading | escape }}"
                    class="phc-stage__product-img threshold-filter"
                    loading="lazy"
                  >
                {% else %}
                  {{ 'product-1' | placeholder_svg_tag: 'phc-stage__product-img threshold-filter' }}
                {% endif %}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Navigation -->
    {% if section.blocks.size > 1 %}
      <div class="phc-nav-wrap">
        {% if section.settings.show_arrows %}
          <div class="phc-arrows">
            <button class="phc-arrow phc-arrow--prev" aria-label="Previous slide">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="phc-arrow phc-arrow--next" aria-label="Next slide">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        {% endif %}
        
        {% if section.settings.show_pagination %}
          <div class="phc-nav">
            {% for block in section.blocks %}
              <button class="phc-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</button>
            {% endfor %}
          </div>
        {% endif %}
      </div>
    {% endif %}
  </premium-hero-carousel>
</section>

<script>
  if (!customElements.get('premium-hero-carousel')) {
    class PremiumHeroCarousel extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.phc-track');
        this.slides = Array.from(this.querySelectorAll('.phc-slide'));
        this.dots = Array.from(this.querySelectorAll('.phc-dot'));
        this.prevBtn = this.querySelector('.phc-arrow--prev');
        this.nextBtn = this.querySelector('.phc-arrow--next');
        
        this.currentIndex = 0;
        this.total = this.slides.length;
        this.autoplay = this.dataset.autoplay === 'true';
        this.speed = parseInt(this.dataset.speed) || 5000;
        this.autoplayTimer = null;
        
        this.init();
      }
      
      init() {
        if (this.total <= 1) return;
        
        if (this.prevBtn) this.prevBtn.addEventListener('click', () => this.goToPrev());
        if (this.nextBtn) this.nextBtn.addEventListener('click', () => this.goToNext());
        
        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goTo(index));
        });
        
        this.initSwipe();
        
        if (this.autoplay) {
          this.startAutoplay();
          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }
      }
      
      goTo(index) {
        if (index === this.currentIndex) return;
        this.currentIndex = index;
        
        this.track.classList.add('is-animating');
        this.track.style.transform = `translateX(-${this.currentIndex * 100}%)`;
        
        setTimeout(() => {
          this.track.classList.remove('is-animating');
        }, 400);

        this.slides.forEach((slide, i) => {
          slide.classList.toggle('is-active', i === this.currentIndex);
          slide.setAttribute('aria-hidden', i !== this.currentIndex);
        });
        
        this.dots.forEach((dot, i) => {
          dot.classList.toggle('is-active', i === this.currentIndex);
        });
      }
      
      goToNext() {
        this.goTo((this.currentIndex + 1) % this.total);
      }
      
      goToPrev() {
        this.goTo((this.currentIndex - 1 + this.total) % this.total);
      }
      
      startAutoplay() {
        this.stopAutoplay();
        this.autoplayTimer = setInterval(() => this.goToNext(), this.speed);
      }
      
      stopAutoplay() {
        if (this.autoplayTimer) clearInterval(this.autoplayTimer);
      }
      
      initSwipe() {
        let touchstartX = 0;
        let touchendX = 0;
        
        this.addEventListener('touchstart', e => {
          touchstartX = e.changedTouches[0].screenX;
        }, { passive: true });
        
        this.addEventListener('touchend', e => {
          touchendX = e.changedTouches[0].screenX;
          if (touchstartX - touchendX > 50) this.goToNext();
          if (touchendX - touchstartX > 50) this.goToPrev();
        }, { passive: true });
      }
    }
    customElements.define('premium-hero-carousel', PremiumHeroCarousel);
  }
</script>

{% schema %}
{
  "name": "Premium Hero Carousel",
  "settings": [
    {
      "type": "select",
      "id": "container_width",
      "label": "Container Width",
      "options": [
        { "value": "standard", "label": "Standard (1600px)" },
        { "value": "narrow", "label": "Narrow (1200px)" },
        { "value": "full", "label": "Full Width" }
      ],
      "default": "standard"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Section Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" },
        { "value": "full", "label": "Full Screen" }
      ],
      "default": "large"
    },
    {
      "type": "header",
      "content": "Controls"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Autoplay Speed (seconds)",
      "min": 3,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show Arrows",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_pagination",
      "label": "Show Pagination Dots",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "settings": [
        {
          "type": "header",
          "content": "Text"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "Introducing"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "The New Standard."
        },
        {
          "type": "range",
          "id": "heading_size_desktop",
          "min": 24,
          "max": 100,
          "step": 2,
          "unit": "px",
          "label": "Heading Desktop Size",
          "default": 64
        },
        {
          "type": "range",
          "id": "heading_size_mobile",
          "min": 16,
          "max": 80,
          "step": 2,
          "unit": "px",
          "label": "Heading Mobile Size",
          "default": 32
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>A premium design experience built seamlessly into your store.</p>"
        },
        {
          "type": "range",
          "id": "desc_size_desktop",
          "min": 10,
          "max": 32,
          "step": 1,
          "unit": "px",
          "label": "Description Desktop Size",
          "default": 14
        },
        {
          "type": "range",
          "id": "desc_size_mobile",
          "min": 10,
          "max": 32,
          "step": 1,
          "unit": "px",
          "label": "Description Mobile Size",
          "default": 14
        },
        {
          "type": "text",
          "id": "btn_text",
          "label": "Button Text",
          "default": "Discover More"
        },
        {
          "type": "url",
          "id": "btn_url",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Media"
        },
        {
          "type": "image_picker",
          "id": "product_image",
          "label": "Product Image (Transparent PNG recommended)"
        },
        {
          "type": "header",
          "content": "Colors (Brutalist)"
        },
        {
          "type": "color",
          "id": "bg_color",
          "label": "Content Background Color",
          "default": "#fbf2eb"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Stage/Button Background Color",
          "default": "#18241b"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Content Text Color",
          "default": "#111111"
        },
        {
          "type": "header",
          "content": "Product Presentation"
        },
        {
          "type": "range",
          "id": "image_scale",
          "label": "Image Scale (%)",
          "min": 50,
          "max": 200,
          "step": 5,
          "default": 100
        },
        {
          "type": "range",
          "id": "rotation",
          "label": "Rotation (deg)",
          "min": -45,
          "max": 45,
          "step": 1,
          "default": 0
        },
        {
          "type": "range",
          "id": "pos_x",
          "label": "Horizontal Offset (Desktop px)",
          "min": -200,
          "max": 200,
          "step": 5,
          "default": 0
        },
        {
          "type": "range",
          "id": "pos_y",
          "label": "Vertical Offset (Desktop px)",
          "min": -200,
          "max": 200,
          "step": 5,
          "default": 0
        },
        {
          "type": "range",
          "id": "pos_x_mobile",
          "label": "Horizontal Offset (Mobile px)",
          "min": -100,
          "max": 100,
          "step": 5,
          "default": 0
        },
        {
          "type": "range",
          "id": "pos_y_mobile",
          "label": "Vertical Offset (Mobile px)",
          "min": -100,
          "max": 100,
          "step": 5,
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Hero Carousel"
    }
  ]
}
{% endschema %}
