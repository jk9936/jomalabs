<section class="max-w-7xl mx-auto px-4 py-16 md:py-24" id="story-{{ section.id }}">
  <div class="border-3 border-text-dark bg-surface shadow-brutalist overflow-hidden relative">
    
    <!-- System Bar -->
    <div class="w-full h-8 bg-text-dark flex items-center px-3 border-b-3 border-text-dark justify-between">
      <span class="font-mono text-xs font-bold text-surface">SYS.STORY_VIEWER</span>
      <div class="flex gap-2">
        <div class="w-3 h-3 bg-cyan-accent border-2 border-text-dark"></div>
        <div class="w-3 h-3 bg-magenta-accent border-2 border-text-dark"></div>
        <div class="w-3 h-3 bg-primary border-2 border-text-dark"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2">
      <!-- Media Area -->
      <div class="border-b-3 lg:border-b-0 lg:border-r-3 border-text-dark bg-background-light p-6 md:p-12 flex items-center justify-center relative overflow-hidden group">
        {%- assign media_block = section.blocks | where: "type", "media" | first -%}
        {%- if media_block -%}
          {%- if media_block.settings.image != blank -%}
            <style>
              #story-{{ section.id }} .story-img {
                height: {{ media_block.settings.image_height_mobile }}px;
                object-position: {{ media_block.settings.image_position }};
              }
              @media (min-width: 1024px) {
                #story-{{ section.id }} .story-img {
                  height: {{ media_block.settings.image_height_desktop }}px;
                }
              }
            </style>
            <img src="{{ media_block.settings.image | image_url: width: 1000 }}" alt="{{ media_block.settings.image.alt | escape }}" class="story-img w-full object-cover border-3 border-text-dark filter hover:brightness-110 shadow-brutalist group-hover:-translate-y-2 group-hover:translate-x-2 transition-transform" loading="lazy">
          {%- endif -%}
        {%- else -%}
          <div class="w-full h-[400px] border-3 border-text-dark flex items-center justify-center font-mono font-bold text-text-dark bg-yellow-accent shadow-brutalist">
            NO_MEDIA_MOUNTED
          </div>
        {%- endif -%}
      </div>

      <!-- Content Area -->
      <div class="p-8 md:p-12 flex flex-col gap-8 justify-center bg-white">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'header' -%}
              <div {{ block.shopify_attributes }}>
                {%- if block.settings.eyebrow != blank -%}
                  <span class="font-mono text-xs font-bold uppercase tracking-widest border-2 border-text-dark px-3 py-1 bg-yellow-accent text-text-dark inline-block mb-4">[{{ block.settings.eyebrow | escape }}]</span>
                {%- endif -%}
                <h2 class="font-display font-bold text-4xl md:text-6xl uppercase leading-none text-text-dark tracking-tight">
                  {{ block.settings.title | escape }}
                </h2>
              </div>
              
            {%- when 'text' -%}
              <div class="font-mono text-sm md:text-base font-bold text-text-dark leading-relaxed border-l-4 border-text-dark pl-4 bg-background-light py-2" {{ block.shopify_attributes }}>
                >>> {{ block.settings.text | strip_html }}
              </div>
              
            {%- when 'stats' -%}
              <div class="grid grid-cols-2 md:grid-cols-3 gap-4 border-t-3 border-b-3 border-text-dark py-6 my-4" {{ block.shopify_attributes }}>
                {%- if block.settings.stat_1_value != blank -%}
                  <div class="flex flex-col">
                    <span class="font-display font-bold text-3xl text-text-dark">{{ block.settings.stat_1_value | escape }}</span>
                    <span class="font-mono text-xs font-bold uppercase text-text-dark">{{ block.settings.stat_1_label | escape }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.stat_2_value != blank -%}
                  <div class="flex flex-col">
                    <span class="font-display font-bold text-3xl text-text-dark">{{ block.settings.stat_2_value | escape }}</span>
                    <span class="font-mono text-xs font-bold uppercase text-text-dark">{{ block.settings.stat_2_label | escape }}</span>
                  </div>
                {%- endif -%}
                {%- if block.settings.stat_3_value != blank -%}
                  <div class="flex flex-col">
                    <span class="font-display font-bold text-3xl text-text-dark">{{ block.settings.stat_3_value | escape }}</span>
                    <span class="font-mono text-xs font-bold uppercase text-text-dark">{{ block.settings.stat_3_label | escape }}</span>
                  </div>
                {%- endif -%}
              </div>
              
            {%- when 'button' -%}
              <a href="{{ block.settings.link | default: '#' }}" class="btn-brutalist inline-block border-3 border-text-dark shadow-brutalist rounded-sm px-6 py-4 font-display font-bold text-lg uppercase tracking-wider text-text-dark bg-cyan-accent hover:bg-surface w-fit mt-4 transition-colors" {{ block.shopify_attributes }}>
                {{ block.settings.label | escape }} &rarr;
              </a>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product Story",
  "settings": [],
  "blocks": [
    {
      "type": "media",
      "name": "Media (Image/Video)",
      "limit": 1,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "header",
          "content": "Image Controls"
        },
        {
          "type": "range",
          "id": "image_height_desktop",
          "label": "Desktop Image Height",
          "min": 200,
          "max": 1000,
          "step": 10,
          "default": 500
        },
        {
          "type": "range",
          "id": "image_height_mobile",
          "label": "Mobile Image Height",
          "min": 200,
          "max": 800,
          "step": 10,
          "default": 400
        },
        {
          "type": "select",
          "id": "image_position",
          "label": "Image Position",
          "options": [
            { "value": "top left", "label": "Top Left" },
            { "value": "top center", "label": "Top Center" },
            { "value": "top right", "label": "Top Right" },
            { "value": "center left", "label": "Center Left" },
            { "value": "center center", "label": "Center Center" },
            { "value": "center right", "label": "Center Right" },
            { "value": "bottom left", "label": "Bottom Left" },
            { "value": "bottom center", "label": "Bottom Center" },
            { "value": "bottom right", "label": "Bottom Right" }
          ],
          "default": "center center"
        }
      ]
    },
    {
      "type": "header",
      "name": "Header Block",
      "settings": [
        {
          "type": "text",
          "id": "eyebrow",
          "label": "Eyebrow Text",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Design Story"
        }
      ]
    },
    {
      "type": "text",
      "name": "Text Block",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Text Content",
          "default": "Every curve and angle is deliberate."
        }
      ]
    },
    {
      "type": "stats",
      "name": "Stats Row",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "stat_1_value", "label": "Stat 1 Value", "default": "12" },
        { "type": "text", "id": "stat_1_label", "label": "Stat 1 Label", "default": "Hours to Print" },
        { "type": "text", "id": "stat_2_value", "label": "Stat 2 Value", "default": "0.1" },
        { "type": "text", "id": "stat_2_label", "label": "Stat 2 Label", "default": "mm Layer Height" },
        { "type": "text", "id": "stat_3_value", "label": "Stat 3 Value" },
        { "type": "text", "id": "stat_3_label", "label": "Stat 3 Label" }
      ]
    },
    {
      "type": "button",
      "name": "Button CTA",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "label", "label": "Button Label", "default": "Read More" },
        { "type": "url", "id": "link", "label": "Button Link" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Story Brutal",
      "blocks": [
        { "type": "media" },
        { "type": "header" },
        { "type": "text" },
        { "type": "stats" },
        { "type": "button" }
      ]
    }
  ]
}
{% endschema %}
